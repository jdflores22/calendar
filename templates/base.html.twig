<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}COROPOTI Calendar{% endblock %}</title>
        <link rel="icon" href="{{ asset('uploads/logos/favicons.ico') }}" type="image/x-icon">
        <link rel="shortcut icon" href="{{ asset('uploads/logos/favicons.ico') }}" type="image/x-icon">
        
        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
            {% if app.user %}
                <!-- Alpine.js for dropdown functionality -->
                <script src="https://unpkg.com/alpinejs@3.14.1/dist/cdn.min.js" defer></script>
                
                <!-- Global System Timezone Configuration -->
                <script>
                    // System-wide timezone configuration - Philippines Standard Time (UTC+8)
                    window.SYSTEM_TIMEZONE_CONFIG = {{ timezone_config_js()|json_encode|raw }};
                    
                    // Global timezone utility functions available throughout the application
                    window.SystemTimezone = {
                        // Get current time in system timezone (Philippines)
                        now: function() {
                            return new Date().toLocaleString("en-US", {timeZone: "{{ system_timezone() }}"});
                        },
                        
                        // Convert any date to system timezone
                        convert: function(date) {
                            return new Date(date.toLocaleString("en-US", {timeZone: "{{ system_timezone() }}"}));
                        },
                        
                        // Format date for datetime-local inputs (Philippines time)
                        formatForInput: function(date) {
                            const systemDate = this.convert(date);
                            return systemDate.toISOString().split('T')[0] + 'T' + systemDate.toTimeString().slice(0, 5);
                        },
                        
                        // Get current date in system timezone (YYYY-MM-DD)
                        getCurrentDate: function() {
                            return this.convert(new Date()).toISOString().split('T')[0];
                        },
                        
                        // Get current time in system timezone (HH:MM)
                        getCurrentTime: function() {
                            return this.convert(new Date()).toTimeString().slice(0, 5);
                        },
                        
                        // Get timezone info
                        getTimezone: function() {
                            return "{{ system_timezone() }}";
                        },
                        
                        // Get timezone offset
                        getOffset: function() {
                            return "{{ system_timezone_offset() }}";
                        },
                        
                        // Format for display with timezone
                        formatWithTimezone: function(date) {
                            return date.toLocaleString('en-US', {
                                timeZone: "{{ system_timezone() }}",
                                year: 'numeric',
                                month: '2-digit',
                                day: '2-digit',
                                hour: '2-digit',
                                minute: '2-digit',
                                second: '2-digit',
                                timeZoneName: 'short'
                            });
                        }
                    };
                    
                    // Log system timezone configuration for debugging
                    console.log('System Timezone Configuration:', window.SYSTEM_TIMEZONE_CONFIG);
                    console.log('Current System Time:', window.SystemTimezone.now());
                </script>
            {% endif %}
        {% endblock %}
        
        <!-- Additional meta tags for better mobile experience -->
        <meta name="theme-color" content="#3B82F6">
        <meta name="description" content="TESDA Calendar Task Management System">
    </head>
