<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}COROPOTI Calendar{% endblock %}</title>
        <link rel="icon" href="{{ asset('uploads/logos/favicons.ico') }}" type="image/x-icon">
        <link rel="shortcut icon" href="{{ asset('uploads/logos/favicons.ico') }}" type="image/x-icon">
        
        {% block stylesheets %}
            {{ encore_entry_link_tags('app') }}
        {% endblock %}

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
        {% endblock %}
        
        <!-- Additional meta tags for better mobile experience -->
        <meta name="theme-color" content="#3B82F6">
        <meta name="description" content="TESDA Calendar Task Management System">
    </head>
    <body class="bg-gray-50">
        {% block body %}{% endblock %}
        
        <!-- Global notification area -->
        <div id="notification-area" class="fixed top-4 right-4 z-50 space-y-2"></div>
        
        <!-- Toast notification system -->
        <div id="toast-container" class="fixed top-4 right-4 z-50 space-y-2"></div>
        
        <!-- Loading indicator -->
        <div id="loading-indicator" class="fixed top-0 left-0 w-full h-1 bg-blue-600 transform scale-x-0 transition-transform duration-300 z-50"></div>
    </body>
</html>
