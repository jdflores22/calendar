{% extends 'base.html.twig' %}

{% block title %}{{ form.name }} - Form Builder - TESDA Calendar{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50">
    <!-- Header -->
    <div class="bg-white shadow">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center py-6">
                <div>
                    <nav class="flex" aria-label="Breadcrumb">
                        <ol class="flex items-center space-x-4">
                            <li>
                                <a href="{{ path('form_builder_index') }}" class="text-gray-400 hover:text-gray-500">
                                    Form Builder
                                </a>
                            </li>
                            <li>
                                <div class="flex items-center">
                                    <svg class="flex-shrink-0 h-5 w-5 text-gray-300" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd"/>
                                    </svg>
                                    <span class="ml-4 text-sm font-medium text-gray-500">{{ form.name }}</span>
                                </div>
                            </li>
                        </ol>
                    </nav>
                    <h1 class="mt-2 text-3xl font-bold text-gray-900">{{ form.name }}</h1>
                    {% if form.description %}
                        <p class="mt-1 text-sm text-gray-500">{{ form.description }}</p>
                    {% endif %}
                </div>
                <div class="flex space-x-3">
                    <a href="{{ path('form_builder_preview', {id: form.id}) }}" 
                       target="_blank"
                       class="inline-flex items-center px-4 py-2 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 bg-white hover:bg-gray-50">
                        <svg class="-ml-1 mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                        </svg>
                        Preview
                    </a>
                    <a href="{{ path('form_builder_edit', {id: form.id}) }}" 
                       class="inline-flex items-center px-4 py-2 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-blue-600 hover:bg-blue-700">
                        <svg class="-ml-1 mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
                        </svg>
                        Edit Form
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Form Details -->
            <div class="lg:col-span-2">
                <!-- Form Fields -->
                <div class="bg-white shadow rounded-lg">
                    <div class="px-4 py-5 sm:px-6">
                        <h3 class="text-lg leading-6 font-medium text-gray-900">Form Fields</h3>
                        <p class="mt-1 max-w-2xl text-sm text-gray-500">{{ fields|length }} field{{ fields|length != 1 ? 's' : '' }} in this form</p>
                    </div>
                    
                    {% if fields|length > 0 %}
                        <div class="border-t border-gray-200">
                            <ul class="divide-y divide-gray-200">
                                {% for field in fields %}
                                    <li class="px-4 py-4">
                                        <div class="flex items-center justify-between">
                                            <div class="flex items-center">
                                                <div class="flex-shrink-0">
                                                    <span class="inline-flex items-center justify-center h-8 w-8 rounded-full bg-blue-100">
                                                        <svg class="h-4 w-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                                                        </svg>
                                                    </span>
                                                </div>
                                                <div class="ml-4">
                                                    <div class="flex items-center">
                                                        <div class="text-sm font-medium text-gray-900">{{ field.label }}</div>
                                                        {% if field.isRequired %}
                                                            <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-100 text-red-800">
                                                                Required
                                                            </span>
                                                        {% endif %}
                                                    </div>
                                                    <div class="text-sm text-gray-500">
                                                        {{ field.typeDisplayName }}
                                                        {% if field.name %} • {{ field.name }}{% endif %}
                                                    </div>
                                                    {% if field.description %}
                                                        <div class="text-sm text-gray-400 mt-1">{{ field.description }}</div>
                                                    {% endif %}
                                                </div>
                                            </div>
                                            <div class="text-sm text-gray-400">
                                                Order: {{ field.sortOrder }}
                                            </div>
                                        </div>
                                        
                                        {% if field.supportsOptions and field.fieldOptions|length > 0 %}
                                            <div class="mt-3 ml-12">
                                                <div class="text-xs font-medium text-gray-500 mb-1">Options:</div>
                                                <div class="flex flex-wrap gap-1">
                                                    {% for value, label in field.fieldOptions %}
                                                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-800">
                                                            {{ label }}
                                                        </span>
                                                    {% endfor %}
                                                </div>
                                            </div>
                                        {% endif %}
                                        
                                        {% if field.placeholder or field.defaultValue %}
                                            <div class="mt-3 ml-12 grid grid-cols-1 gap-2 sm:grid-cols-2">
                                                {% if field.placeholder %}
                                                    <div>
                                                        <div class="text-xs font-medium text-gray-500">Placeholder:</div>
                                                        <div class="text-xs text-gray-700">{{ field.placeholder }}</div>
                                                    </div>
                                                {% endif %}
                                                {% if field.defaultValue %}
                                                    <div>
                                                        <div class="text-xs font-medium text-gray-500">Default Value:</div>
                                                        <div class="text-xs text-gray-700">{{ field.defaultValue }}</div>
                                                    </div>
                                                {% endif %}
                                            </div>
                                        {% endif %}
                                    </li>
                                {% endfor %}
                            </ul>
                        </div>
                    {% else %}
                        <div class="text-center py-12">
                            <svg class="mx-auto h-12 w-12 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                            </svg>
                            <h3 class="mt-2 text-sm font-medium text-gray-900">No fields</h3>
                            <p class="mt-1 text-sm text-gray-500">This form doesn't have any fields yet.</p>
                            <div class="mt-6">
                                <a href="{{ path('form_builder_edit', {id: form.id}) }}" 
                                   class="inline-flex items-center px-4 py-2 border border-transparent shadow-sm text-sm font-medium rounded-md text-white bg-blue-600 hover:bg-blue-700">
                                    <svg class="-ml-1 mr-2 h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"/>
                                    </svg>
                                    Add Fields
                                </a>
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>

            <!-- Sidebar -->
            <div class="lg:col-span-1">
                <!-- Form Information -->
                <div class="bg-white shadow rounded-lg">
                    <div class="px-4 py-5 sm:px-6">
                        <h3 class="text-lg leading-6 font-medium text-gray-900">Form Information</h3>
                    </div>
                    <div class="border-t border-gray-200 px-4 py-5 sm:px-6">
                        <dl class="space-y-4">
                            <div>
                                <dt class="text-sm font-medium text-gray-500">Form Name</dt>
                                <dd class="mt-1 text-sm text-gray-900">{{ form.name }}</dd>
                            </div>
                            <div>
                                <dt class="text-sm font-medium text-gray-500">Slug</dt>
                                <dd class="mt-1 text-sm text-gray-900 font-mono bg-gray-50 px-2 py-1 rounded">{{ form.slug }}</dd>
                            </div>
                            {% if form.assignedTo %}
                                <div>
                                    <dt class="text-sm font-medium text-gray-500">Assigned To</dt>
                                    <dd class="mt-1 text-sm text-gray-900">{{ form.assignedTo }}</dd>
                                </div>
                            {% endif %}
                            <div>
                                <dt class="text-sm font-medium text-gray-500">Status</dt>
                                <dd class="mt-1">
                                    {% if form.isActive %}
                                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">
                                            Active
                                        </span>
                                    {% else %}
                                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-100 text-red-800">
                                            Inactive
                                        </span>
                                    {% endif %}
                                </dd>
                            </div>
                            <div>
                                <dt class="text-sm font-medium text-gray-500">Total Fields</dt>
                                <dd class="mt-1 text-sm text-gray-900">{{ fields|length }}</dd>
                            </div>
                            <div>
                                <dt class="text-sm font-medium text-gray-500">Created By</dt>
                                <dd class="mt-1 text-sm text-gray-900">{{ form.creator.profile ? form.creator.profile.firstName ~ ' ' ~ form.creator.profile.lastName : form.creator.email }}</dd>
                            </div>
                            <div>
                                <dt class="text-sm font-medium text-gray-500">Created</dt>
                                <dd class="mt-1 text-sm text-gray-900">{{ form.createdAt|date('M j, Y g:i A') }}</dd>
                            </div>
                            <div>
                                <dt class="text-sm font-medium text-gray-500">Last Updated</dt>
                                <dd class="mt-1 text-sm text-gray-900">{{ form.updatedAt|date('M j, Y g:i A') }}</dd>
                            </div>
                            {% if form.tags|length > 0 %}
                                <div>
                                    <dt class="text-sm font-medium text-gray-500">Tags</dt>
                                    <dd class="mt-1">
                                        <div class="flex flex-wrap gap-1">
                                            {% for tag in form.tags %}
                                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-blue-100 text-blue-800">
                                                    {{ tag }}
                                                </span>
                                            {% endfor %}
                                        </div>
                                    </dd>
                                </div>
                            {% endif %}
                        </dl>
                    </div>
                </div>

                <!-- Schema Information -->
                <div class="mt-6 bg-white shadow rounded-lg">
                    <div class="px-4 py-5 sm:px-6">
                        <h3 class="text-lg leading-6 font-medium text-gray-900">Schema Information</h3>
                    </div>
                    <div class="border-t border-gray-200 px-4 py-5 sm:px-6">
                        <dl class="space-y-4">
                            <div>
                                <dt class="text-sm font-medium text-gray-500">Schema Version</dt>
                                <dd class="mt-1 text-sm text-gray-900">{{ form.schemaVersion }}</dd>
                            </div>
                            <div>
                                <dt class="text-sm font-medium text-gray-500">Valid Schema</dt>
                                <dd class="mt-1">
                                    {% if form.isValidSchema %}
                                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-green-100 text-green-800">
                                            <svg class="-ml-0.5 mr-1.5 h-2 w-2" fill="currentColor" viewBox="0 0 8 8">
                                                <circle cx="4" cy="4" r="3"/>
                                            </svg>
                                            Valid
                                        </span>
                                    {% else %}
                                        <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-red-100 text-red-800">
                                            <svg class="-ml-0.5 mr-1.5 h-2 w-2" fill="currentColor" viewBox="0 0 8 8">
                                                <circle cx="4" cy="4" r="3"/>
                                            </svg>
                                            Invalid
                                        </span>
                                    {% endif %}
                                </dd>
                            </div>
                        </dl>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}