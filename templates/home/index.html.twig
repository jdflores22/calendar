    // Close dropdown
    closeAllDropdowns();
    
    // Re-render calendar with filter
    renderCalendar();
    
    console.log('Filtering by division:', divisionId);
}

// Show reset button
function showResetButton() {
    const resetBtn = document.getElementById('resetFilterBtn');
    if (resetBtn) {
        resetBtn.classList.remove('hidden');
    }
    
    // Show event list sidebar
    showEventListSidebar();
}

// Hide reset button
function hideResetButton() {
    const resetBtn = document.getElementById('resetFilterBtn');
    if (resetBtn) {
        resetBtn.classList.add('hidden');
    }
    
    // Hide event list sidebar
    hideEventListSidebar();
}

// Show event list sidebar
function showEventListSidebar() {
    const sidebar = document.getElementById('eventListSidebar');
    if (sidebar) {
        sidebar.classList.remove('hidden');
        updateEventList();
    }
}

// Hide event list sidebar
function hideEventListSidebar() {
    const sidebar = document.getElementById('eventListSidebar');
    if (sidebar) {
        sidebar.classList.add('hidden');
    }
}

// Update event list in sidebar
function updateEventList() {
    const eventListContent = document.getElementById('eventListContent');
    const eventListCount = document.getElementById('eventListCount');
    
    if (!eventListContent || !eventListCount) return;
    
    // Get all filtered events for the current month
    const filteredEvents = getFilteredEventsForMonth();
    
    // Update count
    eventListCount.textContent = `${filteredEvents.length} event${filteredEvents.length !== 1 ? 's' : ''}`;
    
    // Generate event list HTML
    if (filteredEvents.length === 0) {
        eventListContent.innerHTML = `
            <div class="text-center py-8 text-slate-400">
                <svg class="w-12 h-12 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
                <p class="text-sm">No events found</p>
            </div>
        `;
        return;
    }
    
    // Sort events by date
    filteredEvents.sort((a, b) => new Date(a.startTime) - new Date(b.startTime));
    
    // Generate HTML
    const eventsHTML = filteredEvents.map(event => {
        const eventDate = new Date(event.startTime);
        const dateStr = eventDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
        const timeStr = eventDate.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' });
        
        return `
            <div class="border border-slate-200 rounded-lg p-3 hover:shadow-md transition-shadow duration-200 cursor-pointer"
                 style="border-left: 3px solid ${event.effectiveColor};"
                 onclick='showEventDetail(${JSON.stringify(event).replace(/'/g, "&#39;")})'>
                <div class="flex items-start justify-between gap-2 mb-2">
                    <h4 class="text-sm font-semibold text-slate-900 line-clamp-2">${event.title}</h4>
                    <span class="text-xs text-slate-500 flex-shrink-0">${dateStr}</span>
                </div>
                <div class="flex items-center gap-2 text-xs text-slate-600">
                    <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span>${timeStr}</span>
                </div>
                ${event.location ? `
                    <div class="flex items-center gap-2 text-xs text-slate-600 mt-1">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                        <span class="truncate">${event.location}</span>
                    </div>
                ` : ''}
            </div>
        `;
    }).join('');
    
    eventListContent.innerHTML = eventsHTML;
}

// Get all filtered events for the current month
function getFilteredEventsForMonth() {
    const firstDay = new Date(currentYear, currentMonth, 1);
    const lastDay = new Date(currentYear, currentMonth + 1, 0);
    
    let filteredEvents = eventsData.filter(event => {
        const eventDate = new Date(event.startTime);
        return eventDate >= firstDay && eventDate <= lastDay;
    });
    
    // Apply active filter
    if (activeFilter.type) {
        filteredEvents = filteredEvents.filter(event => {
            if (activeFilter.type === 'cluster') {
                return event.cluster_id == activeFilter.clusterId;
            } else if (activeFilter.type === 'office') {
                return event.office_id == activeFilter.officeId;
            } else if (activeFilter.type === 'division') {
                return event.office_id == activeFilter.officeId;
            }
            return true;
        });
    }
    
    return filteredEvents;
}

// Update cluster button label
function updateClusterButtonLabel(clusterId, label) {
    const labelElement = document.getElementById('cluster-label-' + clusterId);
    if (labelElement) {
        labelElement.textContent = label;
    }
}

// Close all dropdowns
function closeAllDropdowns() {
    const allPanels = document.querySelectorAll('[id^="cluster-panel-"]');
    allPanels.forEach(p => p.classList.add('hidden'));
    const allArrows = document.querySelectorAll('[id^="cluster-arrow-"]');
    allArrows.forEach(a => a.style.transform = 'rotate(0deg)');
}

// Clear filter (reset to show all)
function clearFilter() {
    activeFilter = {
        type: null,
        clusterId: null,
        officeId: null,
        divisionId: null
    };
    
    // Reset all button labels
    const allLabels = document.querySelectorAll('[id^="cluster-label-"]');
    allLabels.forEach(label => {
        const clusterId = label.id.replace('cluster-label-', '');
        const btn = document.getElementById('cluster-btn-' + clusterId);
        if (btn) {
            // Get original cluster code from button
            const originalCode = btn.getAttribute('data-original-code');
            if (originalCode) {
                label.textContent = originalCode;
            }
        }
    });
    
    // Hide reset button
    hideResetButton();
    
    renderCalendar();
}

// Store original cluster codes on page load
document.addEventListener('DOMContentLoaded', function() {
    const allButtons = document.querySelectorAll('[id^="cluster-btn-"]');
    allButtons.forEach(btn => {
        const label = btn.querySelector('[id^="cluster-label-"]');
        if (label) {
            btn.setAttribute('data-original-code', label.textContent);
        }
    });
});

