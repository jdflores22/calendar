// Event hover tooltip functions
function showEventTooltip(mouseEvent, event) {
    const tooltip = document.getElementById('eventHoverTooltip');
    
    // Parse date strings without timezone conversion
    const [startDatePart, startTimePart] = event.startTime.split(' ');
    const [startYear, startMonth, startDay] = startDatePart.split('-');
    const [startHour, startMinute] = startTimePart.split(':');
    const startDate = new Date(startYear, startMonth - 1, startDay, startHour, startMinute);
    
    const [endDatePart, endTimePart] = event.endTime.split(' ');
    const [endYear, endMonth, endDay] = endDatePart.split('-');
    const [endHour, endMinute] = endTimePart.split(':');
    const endDate = new Date(endYear, endMonth - 1, endDay, endHour, endMinute);
    
    // Priority badge
    const priorityColors = {
        'high': 'tooltip-priority-high',
        'medium': 'tooltip-priority-medium',
        'low': 'tooltip-priority-low'
    };
    const priorityClass = priorityColors[event.priority] || 'tooltip-priority-low';
    const priorityText = event.priority.charAt(0).toUpperCase() + event.priority.slice(1);
    
    // Meeting type display
    const meetingTypeIcons = {
        'in-person': '<svg class="tooltip-icon mr-2 mt-0.5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" /></svg>',
        'zoom': '<svg class="tooltip-icon mr-2 mt-0.5" style="color: #2D8CFF;" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg>',
        'hybrid': '<svg class="tooltip-icon mr-2 mt-0.5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9" /></svg>',
        'other': '<svg class="tooltip-icon mr-2 mt-0.5 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>'
    };
    const meetingTypeLabels = {
        'in-person': 'In-Person',
        'zoom': 'Zoom Meeting',
        'hybrid': 'Hybrid',
        'other': 'Other'
    };
    const meetingTypeIcon = meetingTypeIcons[event.meetingType] || meetingTypeIcons['other'];
    const meetingTypeLabel = meetingTypeLabels[event.meetingType] || 'Other';
    
    const tooltipContent = `
        <div class="space-y-3">
            <div>
                <div class="font-semibold text-slate-900 text-base mb-2">${event.title}</div>
                <div class="flex items-center gap-2 flex-wrap">
                    <span class="tooltip-badge ${priorityClass}">${priorityText}</span>
                    <span class="tooltip-badge tooltip-status">Confirmed</span>
                </div>
            </div>
            
            <div class="space-y-2 text-sm">
                <div class="flex items-start text-slate-700">
                    <svg class="tooltip-icon mr-2 mt-0.5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <div>
                        ${(() => {
                            // Check if event spans multiple days
                            const startDateOnly = new Date(startYear, startMonth - 1, startDay);
                            const endDateOnly = new Date(endYear, endMonth - 1, endDay);
                            const isMultiDay = startDateOnly.getTime() !== endDateOnly.getTime();
                            
                            if (isMultiDay) {
                                // Multi-day event: show start date - end date with times
                                return `<div class="font-medium">${startDate.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' })} • ${!event.allDay ? startDate.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' }) : 'All Day'} - ${endDate.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' })} • ${!event.allDay ? endDate.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' }) : 'All Day'}</div>`;
                            } else {
                                // Single day event: show only start and end times
                                return `<div class="font-medium">${startDate.toLocaleDateString('en-US', { weekday: 'short', month: 'short', day: 'numeric' })} • ${!event.allDay ? startDate.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' }) + ' - ' + endDate.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' }) : 'All Day'}</div>`;
                            }
                        })()}
                    </div>
                </div>
                
                <div class="flex items-start text-slate-700">
                    ${meetingTypeIcon}
                    <div>${meetingTypeLabel}</div>
                </div>
                
                ${event.location ? `
                <div class="flex items-start text-slate-700">
                    <svg class="tooltip-icon mr-2 mt-0.5 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    <div>${event.location}</div>
                </div>
                ` : ''}
                
                ${event.zoomLink ? `
                <div class="flex items-start text-slate-700">
                    <svg class="tooltip-icon mr-2 mt-0.5" style="color: #2D8CFF;" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                    </svg>
                    <div class="truncate">
                        <a href="${event.zoomLink}" target="_blank" rel="noopener noreferrer" class="hover:underline" style="color: #2D8CFF;">Join Zoom Meeting</a>
                    </div>
                </div>
                ` : ''}
                
                ${event.description ? `
                <div class="flex items-start text-slate-600">
                    <svg class="tooltip-icon mr-2 mt-0.5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7" />
                    </svg>
                    <div class="line-clamp-2">${event.description}</div>
                </div>
                ` : ''}
            </div>
            
            <div class="pt-2 border-t border-slate-200 flex items-center justify-center text-xs text-slate-500">
                <svg class="w-4 h-4 mr-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
                Click to view full details
            </div>
        </div>
    `;
    
    tooltip.innerHTML = tooltipContent;
    tooltip.classList.add('show');
    
    // Position tooltip near mouse with offset
    const updatePosition = (e) => {
        const offsetX = 15;
        const offsetY = 15;
        let left = e.clientX + offsetX;
        let top = e.clientY + offsetY;
        
        // Get tooltip dimensions after content is set
        const tooltipRect = tooltip.getBoundingClientRect();
        
        // Adjust if tooltip goes off right edge
        if (left + tooltipRect.width > window.innerWidth - 10) {
            left = e.clientX - tooltipRect.width - offsetX;
        }
        
        // Adjust if tooltip goes off bottom edge
        if (top + tooltipRect.height > window.innerHeight - 10) {
            top = e.clientY - tooltipRect.height - offsetY;
        }
        
        // Ensure tooltip doesn't go off left edge
        if (left < 10) {
            left = 10;
        }
        
        // Ensure tooltip doesn't go off top edge
        if (top < 10) {
            top = 10;
        }
        
        tooltip.style.left = left + 'px';
        tooltip.style.top = top + 'px';
    };
    
    updatePosition(mouseEvent);
    
    // Store the update function so we can track mouse movement
    mouseEvent.target._tooltipUpdate = updatePosition;
    mouseEvent.target.addEventListener('mousemove', updatePosition);
}

function hideEventTooltip() {
    const tooltip = document.getElementById('eventHoverTooltip');
    tooltip.classList.remove('show');
    
    // Remove mousemove listener from all calendar event items
    document.querySelectorAll('.calendar-event-item').forEach(item => {
        if (item._tooltipUpdate) {
            item.removeEventListener('mousemove', item._tooltipUpdate);
            delete item._tooltipUpdate;
        }
    });
}
</script>
{% endblock %}
