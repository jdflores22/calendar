function closeEventModal() {
    document.getElementById('eventDetailModal').classList.add('hidden');
    document.body.style.overflow = 'auto';
}

function previousMonth() {
    currentMonth--;
    if (currentMonth < 0) {
        currentMonth = 11;
        currentYear--;
    }
    renderCalendar();
}

function nextMonth() {
    currentMonth++;
    if (currentMonth > 11) {
        currentMonth = 0;
        currentYear++;
    }
    renderCalendar();
}

function goToToday() {
    currentDate = new Date();
    currentMonth = currentDate.getMonth();
    currentYear = currentDate.getFullYear();
    renderCalendar();
}

// Toggle cluster dropdown
function toggleClusterDropdown(clusterId) {
    const panel = document.getElementById('cluster-panel-' + clusterId);
    const arrow = document.getElementById('cluster-arrow-' + clusterId);
    const allPanels = document.querySelectorAll('[id^="cluster-panel-"]');
    const allArrows = document.querySelectorAll('[id^="cluster-arrow-"]');
    
    // Close all other panels and reset arrows
    allPanels.forEach(p => {
        if (p.id !== 'cluster-panel-' + clusterId) {
            p.classList.add('hidden');
        }
    });
    
    allArrows.forEach(a => {
        if (a.id !== 'cluster-arrow-' + clusterId) {
            a.style.transform = 'rotate(0deg)';
        }
    });
    
    // Toggle current panel and arrow
    const isHidden = panel.classList.contains('hidden');
    panel.classList.toggle('hidden');
    arrow.style.transform = isHidden ? 'rotate(180deg)' : 'rotate(0deg)';
}

// Close dropdowns when clicking outside
document.addEventListener('click', function(e) {
    if (!e.target.closest('[id^="cluster-dropdown-"]')) {
        const allPanels = document.querySelectorAll('[id^="cluster-panel-"]');
        allPanels.forEach(p => p.classList.add('hidden'));
        const allArrows = document.querySelectorAll('[id^="cluster-arrow-"]');
        allArrows.forEach(a => a.style.transform = 'rotate(0deg)');
    }
});

// Filter state
let activeFilter = {
    type: null, // 'cluster', 'office', or 'division'
    clusterId: null,
    officeId: null,
    divisionId: null
};

// Filter by cluster - shows all offices and divisions in the cluster
function filterByCluster(clusterId, clusterCode, clusterColor) {
    activeFilter = {
        type: 'cluster',
        clusterId: clusterId,
        officeId: null,
        divisionId: null
    };
    
    // Update button label
    updateClusterButtonLabel(clusterId, clusterCode + ' (All)');
    
    // Show reset button
    showResetButton();
    
    // Close dropdown
    closeAllDropdowns();
    
    // Re-render calendar with filter
    renderCalendar();
    
    console.log('Filtering by cluster:', clusterId);
}

// Filter by office - shows only events from this office and its divisions
function filterByOffice(officeId, officeCode, clusterId, clusterCode, clusterColor) {
    activeFilter = {
        type: 'office',
        clusterId: clusterId,
        officeId: officeId,
        divisionId: null
    };
    
    // Update button label
    updateClusterButtonLabel(clusterId, clusterCode + ' › ' + officeCode);
    
    // Show reset button
    showResetButton();
    
    // Close dropdown
    closeAllDropdowns();
    
    // Re-render calendar with filter
    renderCalendar();
    
    console.log('Filtering by office:', officeId);
}

// Filter by division - shows only events from this specific division
function filterByDivision(divisionId, divisionCode, officeId, officeCode, clusterId, clusterCode, clusterColor) {
    activeFilter = {
        type: 'division',
        clusterId: clusterId,
        officeId: officeId,
        divisionId: divisionId
    };
    
    // Update button label
    updateClusterButtonLabel(clusterId, clusterCode + ' › ' + officeCode + ' › ' + divisionCode);
    
    // Show reset button
