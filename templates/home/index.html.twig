            const eventEnd = new Date(event.endTime);
            const timeStr = `${eventStart.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' })} - ${eventEnd.toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' })}`;
            
            schedule += `
                <div class="border-l-4 pl-4 py-3 cursor-pointer hover:bg-slate-50 rounded-r-lg transition-colors duration-200"
                     style="border-color: ${event.effectiveColor};"
                     onclick='showEventDetail(${JSON.stringify(event).replace(/'/g, "&#39;")})'>
                    <div class="flex items-start justify-between gap-4">
                        <div class="flex-1">
                            <h3 class="text-lg font-bold text-slate-900 mb-1">${event.title}</h3>
                            <div class="flex items-center gap-4 text-sm text-slate-600">
                                <div class="flex items-center gap-1">
                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                                    </svg>
                                    <span>${timeStr}</span>
                                </div>
                                ${event.location ? `
                                    <div class="flex items-center gap-1">
                                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                        </svg>
                                        <span>${event.location}</span>
                                    </div>
                                ` : ''}
                            </div>
                            ${event.description ? `<p class="text-sm text-slate-600 mt-2 line-clamp-2">${event.description}</p>` : ''}
                        </div>
                        <div class="w-3 h-3 rounded-full flex-shrink-0 mt-1" style="background-color: ${event.effectiveColor};"></div>
                    </div>
                </div>
            `;
        });
        schedule += '</div>';
    }
    
    schedule += '</div>';
    
    document.getElementById('calendarGrid').innerHTML = schedule;
    document.getElementById('calendarGrid').className = ''; // Remove grid classes for day view
}

function getEventsForDate(dateStr) {
    let filteredEvents = eventsData.filter(event => {
        // Parse the date string (YYYY-MM-DD)
        const checkDate = new Date(dateStr + 'T00:00:00');
        
        // Parse event start and end times
        const eventStart = new Date(event.startTime.replace(' ', 'T'));
        const eventEnd = new Date(event.endTime.replace(' ', 'T'));
        
        // Get just the date parts (without time) for comparison
        const eventStartDate = new Date(eventStart.getFullYear(), eventStart.getMonth(), eventStart.getDate());
        const eventEndDate = new Date(eventEnd.getFullYear(), eventEnd.getMonth(), eventEnd.getDate());
        const checkDateOnly = new Date(checkDate.getFullYear(), checkDate.getMonth(), checkDate.getDate());
        
        // Check if the date falls within the event's date range (inclusive)
        return checkDateOnly >= eventStartDate && checkDateOnly <= eventEndDate;
    });
    
    // Apply active filter
    if (activeFilter.type) {
        filteredEvents = filteredEvents.filter(event => {
            if (activeFilter.type === 'cluster') {
                // Show events from all offices in the cluster
                return event.cluster_id == activeFilter.clusterId;
            } else if (activeFilter.type === 'office') {
                // Show events from this specific office
                return event.office_id == activeFilter.officeId;
            } else if (activeFilter.type === 'division') {
                // Show events from this specific division
                // Note: You'll need to add division_id to events if you want division-level filtering
                // For now, fall back to office filtering
                return event.office_id == activeFilter.officeId;
            }
            
            return true;
        });
    }
    
    return filteredEvents;
}

// Helper function to get file icon based on extension
function getFileIcon(extension, mimeType) {
    const ext = extension.toLowerCase();
    
    // PDF
    if (ext === 'pdf') {
        return `<svg class="w-8 h-8 text-red-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
            <path d="M4 18h12V6h-4V2H4v16zm-2 1V0h10l4 4v16H2v-1z"/>
            <text x="10" y="14" font-size="6" text-anchor="middle" fill="currentColor">PDF</text>
        </svg>`;
    }
    
    // Word documents
    if (ext === 'doc' || ext === 'docx') {
        return `<svg class="w-8 h-8 text-blue-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>`;
    }
    
    // Excel spreadsheets
    if (ext === 'xls' || ext === 'xlsx' || ext === 'csv') {
        return `<svg class="w-8 h-8 text-green-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M3 14h18m-9-4v8m-7 0h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
        </svg>`;
    }
    
    // PowerPoint presentations
    if (ext === 'ppt' || ext === 'pptx') {
        return `<svg class="w-8 h-8 text-orange-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01" />
        </svg>`;
    }
    
    // Images
    if (mimeType && mimeType.startsWith('image/')) {
        return `<svg class="w-8 h-8 text-purple-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
        </svg>`;
    }
    
    // Text files
    if (ext === 'txt') {
        return `<svg class="w-8 h-8 text-gray-600 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>`;
    }
    
    // Default file icon
    return `<svg class="w-8 h-8 text-slate-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
    </svg>`;
}

