{% extends 'base.html.twig' %}

{% block title %}Dashboard - TESDA Calendar{% endblock %}

{% block body %}
    <!-- Page Header -->
    <div class="mb-6 sm:mb-8">
        <h1 class="text-xl sm:text-2xl font-bold text-slate-900">Dashboard</h1>
        <p class="mt-1 text-sm text-slate-600">Welcome back! Here's what's happening today.</p>
    </div>

    <!-- Notifications -->
    {% if notifications %}
        <div class="mb-4 sm:mb-6 space-y-3">
            {% for notification in notifications %}
                <div class="rounded-md p-3 sm:p-4 {% if notification.type == 'success' %}bg-green-50 border border-green-200{% elseif notification.type == 'warning' %}bg-yellow-50 border border-yellow-200{% elseif notification.type == 'error' %}bg-red-50 border border-red-200{% else %}bg-blue-50 border border-blue-200{% endif %} animate-fade-in">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            {% if notification.icon == 'clock' %}
                                <svg class="h-5 w-5 {% if notification.type == 'success' %}text-green-400{% elseif notification.type == 'warning' %}text-yellow-400{% elseif notification.type == 'error' %}text-red-400{% else %}text-blue-400{% endif %}" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd" />
                                </svg>
                            {% elseif notification.icon == 'calendar' %}
                                <svg class="h-5 w-5 {% if notification.type == 'success' %}text-green-400{% elseif notification.type == 'warning' %}text-yellow-400{% elseif notification.type == 'error' %}text-red-400{% else %}text-blue-400{% endif %}" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2-2v16a2 2 0 002 2z" />
                                </svg>
                            {% else %}
                                <svg class="h-5 w-5 {% if notification.type == 'success' %}text-green-400{% elseif notification.type == 'warning' %}text-yellow-400{% elseif notification.type == 'error' %}text-red-400{% else %}text-blue-400{% endif %}" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                </svg>
                            {% endif %}
                        </div>
                        <div class="ml-3 flex-1">
                            <h3 class="text-sm font-medium {% if notification.type == 'success' %}text-green-800{% elseif notification.type == 'warning' %}text-yellow-800{% elseif notification.type == 'error' %}text-red-800{% else %}text-blue-800{% endif %}">
                                {{ notification.title }}
                            </h3>
                            <div class="mt-1 text-sm {% if notification.type == 'success' %}text-green-700{% elseif notification.type == 'warning' %}text-yellow-700{% elseif notification.type == 'error' %}text-red-700{% else %}text-blue-700{% endif %}">
                                {{ notification.message }}
                            </div>
                            {% if notification.action is defined %}
                                <div class="mt-2">
                                    <a href="{{ notification.action.url }}" class="text-sm font-medium {% if notification.type == 'success' %}text-green-800 hover:text-green-900{% elseif notification.type == 'warning' %}text-yellow-800 hover:text-yellow-900{% elseif notification.type == 'error' %}text-red-800 hover:text-red-900{% else %}text-blue-800 hover:text-blue-900{% endif %} underline transition-colors duration-200">
                                        {{ notification.action.text }}
                                    </a>
                                </div>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}

    <!-- Statistics Cards -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-6 mb-6 sm:mb-8">
        <div class="bg-white overflow-hidden shadow-sm rounded-lg hover:shadow-md transition-shadow duration-200">
            <div class="p-3 sm:p-5">
                <div class="flex items-center">
                    <div class="flex-shrink-0">
                        <svg class="h-5 w-5 sm:h-6 sm:w-6 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                        </svg>
                    </div>
                    <div class="ml-3 sm:ml-5 w-0 flex-1">
                        <dl>
                            <dt class="text-xs sm:text-sm font-medium text-slate-500 truncate">Total Events</dt>
                            <dd class="text-base sm:text-lg font-medium text-slate-900">{{ statistics.total ?? 0 }}</dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-white overflow-hidden shadow-sm rounded-lg hover:shadow-md transition-shadow duration-200">
            <div class="p-3 sm:p-5">
                <div class="flex items-center">
                    <div class="flex-shrink-0">
                        <svg class="h-5 w-5 sm:h-6 sm:w-6 text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2-2v16a2 2 0 002 2z" />
                        </svg>
                    </div>
                    <div class="ml-3 sm:ml-5 w-0 flex-1">
                        <dl>
                            <dt class="text-xs sm:text-sm font-medium text-slate-500 truncate">Today's Events</dt>
                            <dd class="text-base sm:text-lg font-medium text-slate-900">{{ statistics.today ?? 0 }}</dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-white overflow-hidden shadow-sm rounded-lg hover:shadow-md transition-shadow duration-200">
            <div class="p-3 sm:p-5">
                <div class="flex items-center">
                    <div class="flex-shrink-0">
                        <svg class="h-5 w-5 sm:h-6 sm:w-6 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2-2v16a2 2 0 002 2z" />
                        </svg>
                    </div>
                    <div class="ml-3 sm:ml-5 w-0 flex-1">
                        <dl>
                            <dt class="text-xs sm:text-sm font-medium text-slate-500 truncate">This Week</dt>
                            <dd class="text-base sm:text-lg font-medium text-slate-900">{{ statistics.thisWeek ?? 0 }}</dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>

        <div class="bg-white overflow-hidden shadow-sm rounded-lg hover:shadow-md transition-shadow duration-200">
            <div class="p-3 sm:p-5">
                <div class="flex items-center">
                    <div class="flex-shrink-0">
                        <svg class="h-5 w-5 sm:h-6 sm:w-6 text-purple-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                        </svg>
                    </div>
                    <div class="ml-3 sm:ml-5 w-0 flex-1">
                        <dl>
                            <dt class="text-xs sm:text-sm font-medium text-slate-500 truncate">Recurring</dt>
                            <dd class="text-base sm:text-lg font-medium text-slate-900">{{ statistics.recurring ?? 0 }}</dd>
                        </dl>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Main Dashboard Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 sm:gap-6">
        <!-- Today's Schedule -->
        <div class="lg:col-span-2">
            <div class="bg-white shadow-sm rounded-lg hover:shadow-md transition-shadow duration-200">
                <div class="px-4 py-5 sm:p-6">
                    <h3 class="text-base sm:text-lg leading-6 font-medium text-slate-900 mb-4">Today's Schedule</h3>
                    {% if todaysEvents %}
                        <div class="space-y-3 max-h-96 overflow-y-auto">
                            {% for event in todaysEvents %}
                                <div class="flex items-center p-3 bg-slate-50 rounded-lg hover:bg-slate-100 transition-colors duration-200 cursor-pointer" onclick="window.location.href='{{ path('app_event_show', {id: event.id}) }}'">
                                    <div class="flex-shrink-0">
                                        <div class="w-3 h-3 rounded-full" style="background-color: {{ event.effectiveColor }}"></div>
                                    </div>
                                    <div class="ml-3 flex-1 min-w-0">
                                        <div class="flex items-center justify-between">
                                            <p class="text-sm font-medium text-slate-900 truncate">{{ event.title }}</p>
                                            <div class="flex items-center text-sm text-slate-500">
                                                {% if event.isHappening %}
                                                    <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800 animate-pulse">
                                                        Live
                                                    </span>
                                                {% endif %}
                                            </div>
                                        </div>
                                        <div class="flex items-center mt-1 text-xs sm:text-sm">
                                            <p class="text-slate-500">
                                                {{ event.startTime|ph_date('g:i A') }} - {{ event.endTime|ph_date('g:i A') }}
                                            </p>
                                            {% if event.location %}
                                                <span class="mx-2 text-slate-300">•</span>
                                                <p class="text-slate-500 truncate">{{ event.location }}</p>
                                            {% endif %}
                                        </div>
                                        {% if event.office %}
                                            <p class="text-xs text-slate-400 mt-1">{{ event.office.name }}</p>
                                        {% endif %}
                                    </div>
                                    <div class="ml-3 flex-shrink-0">
                                        <svg class="h-5 w-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                        </svg>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <div class="text-center py-8 sm:py-12">
                            <svg class="mx-auto h-10 w-10 sm:h-12 sm:w-12 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2-2v16a2 2 0 002 2z" />
                            </svg>
                            <h3 class="mt-2 text-sm font-medium text-slate-900">No events today</h3>
                            <p class="mt-1 text-sm text-slate-500">You have a free day ahead!</p>
                            <div class="mt-4">
                                <a href="{{ path('app_event_new') }}" class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors duration-200">
                                    <svg class="mr-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                                    </svg>
                                    Create Event
                                </a>
                            </div>
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

        <!-- Sidebar -->
        <div class="space-y-4 sm:space-y-6">
            <!-- Office Color Legend -->
            <div class="bg-white shadow-sm rounded-lg hover:shadow-md transition-shadow duration-200">
                <div class="px-4 py-5 sm:p-6">
                    <h3 class="text-base sm:text-lg leading-6 font-medium text-slate-900 mb-4">Office Colors</h3>
                    {% if offices %}
                        <div class="space-y-2 max-h-48 overflow-y-auto">
                            {% for office in offices %}
                                <div class="flex items-center">
                                    <div class="w-4 h-4 rounded-full flex-shrink-0" style="background-color: {{ office.color }}"></div>
                                    <span class="ml-3 text-sm text-slate-700 truncate">{{ office.name }}</span>
                                </div>
                            {% endfor %}
                        </div>
                    {% else %}
                        <p class="text-sm text-slate-500">No offices configured</p>
                    {% endif %}
                </div>
            </div>

            <!-- Upcoming Events (Original) -->
            <div class="bg-white shadow-sm rounded-lg hover:shadow-md transition-shadow duration-200">
                <div class="px-4 py-5 sm:p-6">
                    <h3 class="text-base sm:text-lg leading-6 font-medium text-slate-900 mb-4">Upcoming Events</h3>
                    {% if upcomingEvents %}
                        <div class="space-y-3 max-h-64 overflow-y-auto">
                            {% for event in upcomingEvents|slice(0, 5) %}
                                <div class="flex items-start hover:bg-slate-50 p-2 rounded transition-colors duration-200 cursor-pointer" onclick="window.location.href='{{ path('app_event_show', {id: event.id}) }}'">
                                    <div class="flex-shrink-0">
                                        <div class="w-2 h-2 rounded-full mt-2" style="background-color: {{ event.effectiveColor }}"></div>
                                    </div>
                                    <div class="ml-3 flex-1 min-w-0">
                                        <p class="text-sm font-medium text-slate-900 truncate">{{ event.title }}</p>
                                        <p class="text-xs text-slate-500">
                                            {{ event.startTime|ph_date('M j, g:i A') }}
                                        </p>
                                    </div>
                                </div>
                            {% endfor %}
                        </div>
                        {% if upcomingEvents|length > 5 %}
                            <div class="mt-4">
                                <a href="{{ path('app_event_index') }}" class="text-sm text-indigo-600 hover:text-indigo-900 transition-colors duration-200">
                                    View all {{ upcomingEvents|length }} upcoming events →
                                </a>
                            </div>
                        {% endif %}
                    {% else %}
                        <p class="text-sm text-slate-500">No upcoming events</p>
                    {% endif %}
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="bg-white shadow-sm rounded-lg hover:shadow-md transition-shadow duration-200">
                <div class="px-4 py-5 sm:p-6">
                    <h3 class="text-base sm:text-lg leading-6 font-medium text-slate-900 mb-4">Quick Actions</h3>
                    <div class="space-y-3">
                        <a href="{{ path('app_event_new') }}" class="w-full inline-flex justify-center items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all duration-200 transform hover:scale-105">
                            <svg class="mr-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                            </svg>
                            Create Event
                        </a>
                        <a href="{{ path('app_calendar_index') }}" class="w-full inline-flex justify-center items-center px-4 py-2 border border-slate-300 text-sm font-medium rounded-md text-slate-700 bg-white hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all duration-200 transform hover:scale-105">
                            <svg class="mr-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2-2v16a2 2 0 002 2z" />
                            </svg>
                            View Calendar
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Floating Action Button for Mobile -->
    <div class="lg:hidden fixed bottom-4 right-4 z-50">
        <a href="{{ path('app_event_new') }}" class="bg-indigo-600 rounded-full p-4 text-white shadow-lg hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-all duration-200 transform hover:scale-110">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
            </svg>
        </a>
    </div>
{% endblock %}