// Reminder functionality
function setReminder(minutesBefore) {
    if (!('Notification' in window)) {
        alert('This browser does not support notifications');
        return;
    }
    
    if (Notification.permission === 'denied') {
        alert('Notifications are blocked. Please enable them in your browser settings.');
        return;
    }
    
    if (Notification.permission === 'default') {
        Notification.requestPermission().then(permission => {
            if (permission === 'granted') {
                scheduleReminder(minutesBefore);
            }
        });
    } else {
        scheduleReminder(minutesBefore);
    }
}

function scheduleReminder(minutesBefore) {
    const eventStart = new Date('{{ event.startTime|date('Y-m-d\\TH:i:s') }}');
    const reminderTime = new Date(eventStart.getTime() - (minutesBefore * 60 * 1000));
    const now = new Date();
    
    if (reminderTime <= now) {
        if (window.showToast) {
            window.showToast('Cannot set reminder for past time', 'error');
        } else {
            alert('Cannot set reminder for past time');
        }
        return;
    }
    
    const timeUntilReminder = reminderTime.getTime() - now.getTime();
    
    setTimeout(() => {
        new Notification('Event Reminder', {
            body: `{{ event.title|e('js') }} starts in ${minutesBefore} minutes`,
            icon: '/favicon.ico',
            tag: 'event-reminder-{{ event.id }}'
        });
    }, timeUntilReminder);
    
    // Store reminder in localStorage
    const reminders = JSON.parse(localStorage.getItem('eventReminders') || '[]');
    reminders.push({
        eventId: {{ event.id }},
        eventTitle: '{{ event.title|e('js') }}',
        reminderTime: reminderTime.toISOString(),
        minutesBefore: minutesBefore
    });
    localStorage.setItem('eventReminders', JSON.stringify(reminders));
    
    const timeText = minutesBefore >= 1440 ? `${Math.floor(minutesBefore/1440)} day(s)` : 
                     minutesBefore >= 60 ? `${Math.floor(minutesBefore/60)} hour(s)` : 
                     `${minutesBefore} minute(s)`;
    
    if (window.showToast) {
        window.showToast(`Reminder set for ${timeText} before the event`, 'success');
    } else {
        alert(`Reminder set for ${timeText} before the event`);
    }
}

// Check for pending reminders on page load
document.addEventListener('DOMContentLoaded', function() {
    const reminders = JSON.parse(localStorage.getItem('eventReminders') || '[]');
    const now = new Date();
    
    reminders.forEach(reminder => {
        const reminderTime = new Date(reminder.reminderTime);
        if (reminderTime > now) {
            const timeUntilReminder = reminderTime.getTime() - now.getTime();
            setTimeout(() => {
                new Notification('Event Reminder', {
                    body: `${reminder.eventTitle} starts in ${reminder.minutesBefore} minutes`,
                    icon: '/favicon.ico',
                    tag: `event-reminder-${reminder.eventId}`
                });
            }, timeUntilReminder);
        }
    });
    
    // Clean up old reminders
    const activeReminders = reminders.filter(reminder => new Date(reminder.reminderTime) > now);
    localStorage.setItem('eventReminders', JSON.stringify(activeReminders));
});
</script>
