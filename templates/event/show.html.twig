<script>
// Copy event link functionality
function copyEventLink() {
    const url = window.location.href;
    navigator.clipboard.writeText(url).then(() => {
        if (window.showToast) {
            window.showToast('Event link copied to clipboard!', 'success');
        } else {
            alert('Event link copied to clipboard!');
        }
    }).catch(err => {
        console.error('Failed to copy: ', err);
        if (window.showToast) {
            window.showToast('Failed to copy link', 'error');
        } else {
            alert('Failed to copy link');
        }
    });
}

// Export to calendar functionality
function exportToCalendar() {
    const event = {
        title: '{{ event.title|e('js') }}',
        start: '{{ event.startTime|date('Y-m-d\\TH:i:s') }}',
        end: '{{ event.endTime|date('Y-m-d\\TH:i:s') }}',
        description: '{{ event.description|default('')|e('js') }}',
        location: '{{ event.location|default('')|e('js') }}'
    };
    
    // Create ICS format
    const icsContent = [
        'BEGIN:VCALENDAR',
        'VERSION:2.0',
        'PRODID:-//Event Calendar//Event//EN',
        'BEGIN:VEVENT',
        `UID:${Date.now()}@eventcalendar.com`,
        `DTSTART:${event.start.replace(/[-:]/g, '').replace('T', 'T')}Z`,
        `DTEND:${event.end.replace(/[-:]/g, '').replace('T', 'T')}Z`,
        `SUMMARY:${event.title}`,
        `DESCRIPTION:${event.description}`,
        `LOCATION:${event.location}`,
        'END:VEVENT',
        'END:VCALENDAR'
    ].join('\r\n');
    
    // Create download link
    const blob = new Blob([icsContent], { type: 'text/calendar' });
    const url = window.URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = `${event.title.replace(/[^a-z0-9]/gi, '_').toLowerCase()}.ics`;
    document.body.appendChild(link);
    link.click();
    document.body.removeChild(link);
    window.URL.revokeObjectURL(url);
    
    if (window.showToast) {
        window.showToast('Calendar file downloaded!', 'success');
    }
}

