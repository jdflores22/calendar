{% extends 'base.html.twig' %}

{% block title %}Edit Event - {{ event.title }}{% endblock %}

{% block body %}
<div class="min-h-screen bg-gray-50">
    <header class="bg-white shadow-sm border-b border-gray-200">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center py-4">
                <h1 class="text-2xl font-bold text-gray-900">Edit Event</h1>
                <div class="flex items-center space-x-4">
                    <a href="{{ path('app_event_show', {id: event.id}) }}" class="text-blue-600 hover:text-blue-800">
                        View Event
                    </a>
                    <a href="{{ path('app_calendar_index') }}" class="text-blue-600 hover:text-blue-800">
                        Back to Calendar
                    </a>
                </div>
            </div>
        </div>
    </header>

    <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Flash Messages -->
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 rounded-md p-4 {% if type == 'success' %}bg-green-50 border border-green-200{% elseif type == 'error' %}bg-red-50 border border-red-200{% elseif type == 'warning' %}bg-yellow-50 border border-yellow-200{% else %}bg-blue-50 border border-blue-200{% endif %}">
                    <div class="flex">
                        <div class="flex-shrink-0">
                            {% if type == 'success' %}
                                <svg class="h-5 w-5 text-green-400" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                                </svg>
                            {% elseif type == 'error' %}
                                <svg class="h-5 w-5 text-red-400" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                                </svg>
                            {% elseif type == 'warning' %}
                                <svg class="h-5 w-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                                </svg>
                            {% else %}
                                <svg class="h-5 w-5 text-blue-400" fill="currentColor" viewBox="0 0 20 20">
                                    <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
                                </svg>
                            {% endif %}
                        </div>
                        <div class="ml-3">
                            <p class="text-sm {% if type == 'success' %}text-green-800{% elseif type == 'error' %}text-red-800{% elseif type == 'warning' %}text-yellow-800{% else %}text-blue-800{% endif %}">
                                {{ message }}
                            </p>
                        </div>
                        <div class="ml-auto pl-3">
                            <div class="-mx-1.5 -my-1.5">
                                <button type="button" onclick="this.parentElement.parentElement.parentElement.parentElement.remove()" class="inline-flex rounded-md p-1.5 {% if type == 'success' %}text-green-500 hover:bg-green-100{% elseif type == 'error' %}text-red-500 hover:bg-red-100{% elseif type == 'warning' %}text-yellow-500 hover:bg-yellow-100{% else %}text-blue-500 hover:bg-blue-100{% endif %} focus:outline-none focus:ring-2 focus:ring-offset-2 {% if type == 'success' %}focus:ring-green-600{% elseif type == 'error' %}focus:ring-red-600{% elseif type == 'warning' %}focus:ring-yellow-600{% else %}focus:ring-blue-600{% endif %}">
                                    <span class="sr-only">Dismiss</span>
                                    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M4.293 4.293a1 1 0 011.414 0L10 8.586l4.293-4.293a1 1 0 111.414 1.414L11.414 10l4.293 4.293a1 1 0 01-1.414 1.414L10 11.414l-4.293 4.293a1 1 0 01-1.414-1.414L8.586 10 4.293 5.707a1 1 0 010-1.414z" clip-rule="evenodd" />
                                    </svg>
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        {% endfor %}

        <div class="bg-white shadow rounded-lg">
            <div class="px-6 py-4 border-b border-gray-200">
                <h2 class="text-lg font-medium text-gray-900">Event Details</h2>
            </div>
            
            <form method="POST" class="px-6 py-6" id="eventEditForm" onsubmit="return handleFormSubmission(event);">
                <input type="hidden" name="_token" value="{{ csrf_token('event_form') }}">
                <div class="grid grid-cols-1 gap-y-6 gap-x-4 sm:grid-cols-2">
                    <div class="sm:col-span-2">
                        <label for="title" class="block text-sm font-medium text-gray-700">Title *</label>
                        <input type="text" name="title" id="title" required
                               value="{{ event.title ?? '' }}"
                               class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500">
                    </div>

                    <div>
                        <label for="start" class="block text-sm font-medium text-gray-700">Start Date & Time *</label>
                        <input type="datetime-local" name="start" id="start" required
                               value="{{ event.startTime ? event.startTime|ph_datetime_local : '' }}"
                               class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500">
                    </div>

                    <div>
                        <label for="end" class="block text-sm font-medium text-gray-700">End Date & Time *</label>
                        <input type="datetime-local" name="end" id="end" required
                               value="{{ event.endTime ? event.endTime|ph_datetime_local : '' }}"
                               class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500">
                    </div>

                    <div>
                        <label for="office_id" class="block text-sm font-medium text-gray-700">Primary Office</label>
                        <select name="office_id" id="office_id"
                                class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 bg-gray-50"
                                readonly disabled>
                            <option value="">Select primary office</option>
                            {% for office in offices %}
                                <option value="{{ office.id }}" 
                                        data-color="{{ office.color ?? '#007BFF' }}"
                                        data-name="{{ office.name }}"
                                        {% if event.office and event.office.id == office.id %}selected{% endif %}>
                                    {{ office.name }}
                                </option>
                            {% endfor %}
                        </select>
                        <input type="hidden" name="office_id" value="{{ event.office ? event.office.id : '' }}">
                        <p class="mt-1 text-xs text-gray-500">
                            <svg class="w-3 h-3 inline mr-1" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
                            </svg>
                            Automatically assigned based on event creator's office
                        </p>
                    </div>

                    <!-- Tagged Offices Selection -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                            Tagged Offices
                            <span class="text-gray-500 font-normal">(Select all offices involved in this meeting)</span>
                        </label>
                        <div class="space-y-2 max-h-48 overflow-y-auto border border-gray-200 rounded-md p-3 bg-white">
                            {% for office in offices %}
                                <label class="flex items-center space-x-3 p-2 rounded-md hover:bg-gray-50 transition-colors duration-200 cursor-pointer">
                                    <input type="checkbox" 
                                           name="tagged_office_ids[]" 
                                           value="{{ office.id }}"
                                           {% if event.taggedOffices and office in event.taggedOffices %}checked{% endif %}
                                           class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded transition-colors duration-200">
                                    <div class="w-4 h-4 rounded-full border-2 border-white shadow-sm" style="background-color: {{ office.color ?? '#007BFF' }};"></div>
                                    <div class="flex-1 min-w-0">
                                        <span class="text-sm font-medium text-gray-900">{{ office.name }}</span>
                                        {% if office.code %}
                                            <span class="text-xs text-gray-500 ml-1">({{ office.code }})</span>
                                        {% endif %}
                                        {% if office.description %}
                                            <p class="text-xs text-gray-600 truncate">{{ office.description }}</p>
                                        {% endif %}
                                    </div>
                                </label>
                            {% endfor %}
                        </div>
                        <p class="mt-2 text-xs text-gray-500">
                            <svg class="w-3 h-3 inline mr-1" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd" />
                            </svg>
                            Tag all offices whose staff will participate in this meeting
                        </p>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-1">Event Color</label>
                        <div class="flex items-center space-x-2 p-3 bg-gray-50 rounded-md border border-gray-200">
                            <div id="colorDisplay" class="w-6 h-6 rounded-full border-2 border-white shadow-sm" style="background-color: {{ event.color ?? '#007BFF' }};"></div>
                            <div class="flex flex-col min-w-0 flex-1">
                                <span id="colorLabel" class="text-xs font-medium text-gray-700 truncate">
                                    {% if event.office %}{{ event.office.name }}{% else %}Default Blue{% endif %}
                                </span>
                                <span id="colorCode" class="text-xs text-gray-500">{{ event.color ?? '#007BFF' }}</span>
                            </div>
                        </div>
                        <input type="hidden" name="color" id="color" value="{{ event.color ?? '#007BFF' }}">
                        <p class="mt-1 text-xs text-gray-500">Color is automatically assigned based on the selected office.</p>
                    </div>

                    <div>
                        <label for="location" class="block text-sm font-medium text-gray-700">Location</label>
                        <input type="text" name="location" id="location"
                               value="{{ event.location ?? '' }}"
                               class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500">
                    </div>

                    <div>
                        <label for="priority" class="block text-sm font-medium text-gray-700">Priority</label>
                        <select name="priority" id="priority"
                                class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500">
                            <option value="low" {% if event.priority == 'low' %}selected{% endif %}>Low</option>
                            <option value="normal" {% if event.priority == 'normal' or not event.priority %}selected{% endif %}>Normal</option>
                            <option value="high" {% if event.priority == 'high' %}selected{% endif %}>High</option>
                            <option value="urgent" {% if event.priority == 'urgent' %}selected{% endif %}>Urgent</option>
                        </select>
                    </div>

                    <div>
                        <label for="status" class="block text-sm font-medium text-gray-700">Status</label>
                        <select name="status" id="status"
                                class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500">
                            <option value="confirmed" {% if event.status == 'confirmed' or not event.status %}selected{% endif %}>Confirmed</option>
                            <option value="tentative" {% if event.status == 'tentative' %}selected{% endif %}>Tentative</option>
                            <option value="cancelled" {% if event.status == 'cancelled' %}selected{% endif %}>Cancelled</option>
                        </select>
                    </div>

                    <div class="flex items-center">
                        <input type="checkbox" name="allDay" id="allDay" value="1"
                               {% if event.allDay %}checked{% endif %}
                               class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded">
                        <label for="allDay" class="ml-2 block text-sm text-gray-900">All Day Event</label>
                    </div>

                    <div class="flex items-center">
                        <input type="checkbox" name="isRecurring" id="isRecurring" value="1"
                               {% if event.isRecurring %}checked{% endif %}
                               class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded">
                        <label for="isRecurring" class="ml-2 block text-sm text-gray-900">Recurring Event</label>
                    </div>

                    <div class="sm:col-span-2" id="recurrenceOptions" style="display: {% if event.isRecurring %}block{% else %}none{% endif %};">
                        <div class="bg-gray-50 p-4 rounded-md border">
                            <h3 class="text-sm font-medium text-gray-900 mb-4">Recurrence Pattern</h3>
                            
                            <div class="grid grid-cols-1 gap-y-4 gap-x-4 sm:grid-cols-2">
                                <div>
                                    <label for="frequency" class="block text-sm font-medium text-gray-700">Frequency</label>
                                    <select name="recurrencePattern[frequency]" id="frequency"
                                            class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500">
                                        <option value="daily" {% if event.recurrencePattern.frequency is defined and event.recurrencePattern.frequency == 'daily' %}selected{% endif %}>Daily</option>
                                        <option value="weekly" {% if event.recurrencePattern.frequency is defined and event.recurrencePattern.frequency == 'weekly' %}selected{% endif %}>Weekly</option>
                                        <option value="monthly" {% if event.recurrencePattern.frequency is defined and event.recurrencePattern.frequency == 'monthly' %}selected{% endif %}>Monthly</option>
                                        <option value="yearly" {% if event.recurrencePattern.frequency is defined and event.recurrencePattern.frequency == 'yearly' %}selected{% endif %}>Yearly</option>
                                    </select>
                                </div>

                                <div>
                                    <label for="interval" class="block text-sm font-medium text-gray-700">Repeat every</label>
                                    <input type="number" name="recurrencePattern[interval]" id="interval" min="1" value="{{ event.recurrencePattern.interval ?? 1 }}"
                                           class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500">
                                </div>

                                <div id="weekdayOptions" style="display: none;" class="sm:col-span-2">
                                    <label class="block text-sm font-medium text-gray-700 mb-2">Days of the week</label>
                                    <div class="flex flex-wrap gap-2">
                                        {% set weekdays = ['monday', 'tuesday', 'wednesday', 'thursday', 'friday', 'saturday', 'sunday'] %}
                                        {% for day in weekdays %}
                                            <label class="inline-flex items-center">
                                                <input type="checkbox" name="recurrencePattern[weekdays][]" value="{{ day }}"
                                                       {% if event.recurrencePattern.weekdays is defined and day in event.recurrencePattern.weekdays %}checked{% endif %}
                                                       class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300 rounded">
                                                <span class="ml-2 text-sm text-gray-700">{{ day|title }}</span>
                                            </label>
                                        {% endfor %}
                                    </div>
                                </div>

                                <div id="monthlyOptions" style="display: none;" class="sm:col-span-2">
                                    <label class="block text-sm font-medium text-gray-700 mb-2">Monthly pattern</label>
                                    <div class="space-y-2">
                                        <label class="inline-flex items-center">
                                            <input type="radio" name="recurrencePattern[monthlyType]" value="dayOfMonth"
                                                   {% if not event.recurrencePattern.monthlyType is defined or event.recurrencePattern.monthlyType == 'dayOfMonth' %}checked{% endif %}
                                                   class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300">
                                            <span class="ml-2 text-sm text-gray-700">Same day of month</span>
                                        </label>
                                        <label class="inline-flex items-center">
                                            <input type="radio" name="recurrencePattern[monthlyType]" value="dayOfWeek"
                                                   {% if event.recurrencePattern.monthlyType is defined and event.recurrencePattern.monthlyType == 'dayOfWeek' %}checked{% endif %}
                                                   class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300">
                                            <span class="ml-2 text-sm text-gray-700">Same day of week (e.g., first Monday)</span>
                                        </label>
                                    </div>
                                </div>

                                <div class="sm:col-span-2">
                                    <label class="block text-sm font-medium text-gray-700 mb-2">End condition</label>
                                    <div class="space-y-2">
                                        <label class="inline-flex items-center">
                                            <input type="radio" name="endCondition" value="never" 
                                                   {% if not event.recurrencePattern.count is defined and not event.recurrencePattern.until is defined %}checked{% endif %}
                                                   class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300">
                                            <span class="ml-2 text-sm text-gray-700">Never</span>
                                        </label>
                                        <label class="inline-flex items-center">
                                            <input type="radio" name="endCondition" value="count"
                                                   {% if event.recurrencePattern.count is defined %}checked{% endif %}
                                                   class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300">
                                            <span class="ml-2 text-sm text-gray-700">After</span>
                                            <input type="number" name="recurrencePattern[count]" min="1" value="{{ event.recurrencePattern.count ?? '' }}"
                                                   class="ml-2 w-16 border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 text-sm">
                                            <span class="ml-1 text-sm text-gray-700">occurrences</span>
                                        </label>
                                        <label class="inline-flex items-center">
                                            <input type="radio" name="endCondition" value="until"
                                                   {% if event.recurrencePattern.until is defined %}checked{% endif %}
                                                   class="h-4 w-4 text-blue-600 focus:ring-blue-500 border-gray-300">
                                            <span class="ml-2 text-sm text-gray-700">Until</span>
                                            <input type="date" name="recurrencePattern[until]" value="{{ event.recurrencePattern.until ?? '' }}"
                                                   class="ml-2 border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 text-sm">
                                        </label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="sm:col-span-2">
                        <label for="description" class="block text-sm font-medium text-gray-700">Description</label>
                        <textarea name="description" id="description" rows="4"
                                  class="mt-1 block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500">{{ event.description ?? '' }}</textarea>
                    </div>

                    <!-- Event Tags Section -->
                    <div class="sm:col-span-2">
                        <label for="tags" class="block text-sm font-medium text-gray-700 mb-2">
                            Event Tags
                            <span class="text-gray-500 font-normal">(Add tags to categorize this event)</span>
                        </label>
                        
                        <!-- Tag Input -->
                        <div class="relative mb-3">
                            <input type="text" 
                                   id="tagInput" 
                                   placeholder="Type to add tags (press Enter or comma to add)"
                                   class="block w-full border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500 text-sm py-2 px-3">
                            <div class="absolute inset-y-0 right-0 pr-3 flex items-center pointer-events-none">
                                <svg class="h-4 w-4 text-gray-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                                </svg>
                            </div>
                        </div>
                        
                        <!-- Selected Tags Display -->
                        <div id="selectedTags" class="flex flex-wrap gap-2 min-h-[2rem] mb-3">
                            <!-- Tags will be added here dynamically -->
                        </div>
                        
                        <!-- Popular Tags -->
                        <div>
                            <label class="block text-xs font-medium text-gray-600 mb-2">Popular Tags:</label>
                            <div id="popularTags" class="flex flex-wrap gap-2">
                                {% if popularTags is defined and popularTags|length > 0 %}
                                    {% for tagData in popularTags %}
                                        <button type="button" class="popular-tag inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-700 hover:bg-blue-100 hover:text-blue-800 transition-colors duration-200" data-tag="{{ tagData[0].name }}">
                                            {{ tagData[0].name }}
                                            <span class="ml-1 text-xs text-gray-500">({{ tagData.eventCount }})</span>
                                        </button>
                                    {% endfor %}
                                {% else %}
                                    <!-- Default popular tags -->
                                    <button type="button" class="popular-tag inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-700 hover:bg-blue-100 hover:text-blue-800 transition-colors duration-200" data-tag="meeting">
                                        meeting
                                    </button>
                                    <button type="button" class="popular-tag inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-700 hover:bg-blue-100 hover:text-blue-800 transition-colors duration-200" data-tag="training">
                                        training
                                    </button>
                                    <button type="button" class="popular-tag inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-700 hover:bg-blue-100 hover:text-blue-800 transition-colors duration-200" data-tag="workshop">
                                        workshop
                                    </button>
                                    <button type="button" class="popular-tag inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-700 hover:bg-blue-100 hover:text-blue-800 transition-colors duration-200" data-tag="conference">
                                        conference
                                    </button>
                                    <button type="button" class="popular-tag inline-flex items-center px-2.5 py-1 rounded-full text-xs font-medium bg-gray-100 text-gray-700 hover:bg-blue-100 hover:text-blue-800 transition-colors duration-200" data-tag="seminar">
                                        seminar
                                    </button>
                                {% endif %}
                            </div>
                        </div>
                        
                        <p class="mt-2 text-xs text-gray-500">
                            Tags help categorize and filter events. Use keywords like "meeting", "training", "urgent", etc.
                        </p>
                    </div>
                </div>

                <div class="mt-6 flex justify-end space-x-3">
                    <a href="{{ path('app_event_show', {id: event.id}) }}" 
                       class="bg-white py-2 px-4 border border-gray-300 rounded-md shadow-sm text-sm font-medium text-gray-700 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500">
                        Cancel
                    </a>
                    <button type="submit" id="updateEventBtn"
                            class="bg-blue-600 py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 disabled:opacity-50 disabled:cursor-not-allowed">
                        Update Event
                    </button>
                </div>
            </form>
        </div>
    </main>
</div>

<script>
// Office color auto-detection functionality
function updateOfficeColor() {
    const officeSelect = document.getElementById('office_id');
    const colorInput = document.getElementById('color');
    const colorDisplay = document.getElementById('colorDisplay');
    const colorLabel = document.getElementById('colorLabel');
    const colorCode = document.getElementById('colorCode');
    
    const selectedOption = officeSelect.options[officeSelect.selectedIndex];
    
    if (selectedOption && selectedOption.value) {
        // Office selected - use office color
        const officeColor = selectedOption.getAttribute('data-color') || '#007BFF';
        const officeName = selectedOption.getAttribute('data-name') || 'Selected Office';
        
        colorInput.value = officeColor;
        colorDisplay.style.backgroundColor = officeColor;
        colorLabel.textContent = officeName;
        colorCode.textContent = officeColor;
    } else {
        // No office selected - use default
        const defaultColor = '#007BFF';
        colorInput.value = defaultColor;
        colorDisplay.style.backgroundColor = defaultColor;
        colorLabel.textContent = 'Default Blue';
        colorCode.textContent = defaultColor;
    }
}

// Handle office selection change
document.getElementById('office_id').addEventListener('change', updateOfficeColor);

// Form submission handler with loading state
function handleFormSubmission(event) {
    console.log('Form submitted');
    
    const form = event.target;
    const submitBtn = document.getElementById('updateEventBtn');
    const startInput = document.getElementById('start');
    const endInput = document.getElementById('end');
    
    // Validate required fields
    if (!startInput.value || !endInput.value) {
        if (window.showToast) {
            window.showToast('Please fill in both start and end times', 'error');
        }
        return false;
    }
    
    // Validate that end time is after start time
    if (new Date(endInput.value) <= new Date(startInput.value)) {
        if (window.showToast) {
            window.showToast('End time must be after start time', 'error');
        }
        return false;
    }
    
    // Show loading state
    if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<svg class="animate-spin -ml-1 mr-3 h-4 w-4 text-white" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>Updating...';
    }
    
    // Show loading notification
    if (window.TesdaCalendar && window.TesdaCalendar.showLoading) {
        window.TesdaCalendar.showLoading();
    }
    
    return true; // Allow form submission to proceed
}

document.getElementById('allDay').addEventListener('change', function() {
    const startInput = document.getElementById('start');
    const endInput = document.getElementById('end');
    
    if (this.checked) {
        // Convert to date-only inputs
        startInput.type = 'date';
        endInput.type = 'date';
    } else {
        // Convert back to datetime inputs
        startInput.type = 'datetime-local';
        endInput.type = 'datetime-local';
    }
});

// Handle recurring event options
document.getElementById('isRecurring').addEventListener('change', function() {
    const recurrenceOptions = document.getElementById('recurrenceOptions');
    recurrenceOptions.style.display = this.checked ? 'block' : 'none';
});

// Handle frequency change
document.getElementById('frequency').addEventListener('change', function() {
    const weekdayOptions = document.getElementById('weekdayOptions');
    const monthlyOptions = document.getElementById('monthlyOptions');
    
    // Hide all frequency-specific options
    weekdayOptions.style.display = 'none';
    monthlyOptions.style.display = 'none';
    
    // Show relevant options based on frequency
    if (this.value === 'weekly') {
        weekdayOptions.style.display = 'block';
    } else if (this.value === 'monthly') {
        monthlyOptions.style.display = 'block';
    }
});

// Handle end condition radio buttons
document.querySelectorAll('input[name="endCondition"]').forEach(function(radio) {
    radio.addEventListener('change', function() {
        // Enable/disable related inputs based on selection
        const countInput = document.querySelector('input[name="recurrencePattern[count]"]');
        const untilInput = document.querySelector('input[name="recurrencePattern[until]"]');
        
        countInput.disabled = this.value !== 'count';
        untilInput.disabled = this.value !== 'until';
        
        // Clear values when disabled
        if (this.value !== 'count') countInput.value = '';
        if (this.value !== 'until') untilInput.value = '';
    });
});

// Initialize frequency-specific options on page load
document.addEventListener('DOMContentLoaded', function() {
    const frequency = document.getElementById('frequency').value;
    const weekdayOptions = document.getElementById('weekdayOptions');
    const monthlyOptions = document.getElementById('monthlyOptions');
    
    if (frequency === 'weekly') {
        weekdayOptions.style.display = 'block';
    } else if (frequency === 'monthly') {
        monthlyOptions.style.display = 'block';
    }
    
    // Initialize end condition inputs
    const selectedEndCondition = document.querySelector('input[name="endCondition"]:checked');
    if (selectedEndCondition) {
        selectedEndCondition.dispatchEvent(new Event('change'));
    }
    
    // Initialize office color display on page load
    updateOfficeColor();
    
    // Event Tags Functionality
    const tagInput = document.getElementById('tagInput');
    const selectedTagsContainer = document.getElementById('selectedTags');
    const popularTagButtons = document.querySelectorAll('.popular-tag');
    let selectedTags = [{% for tag in event.tags %}'{{ tag.name|e('js') }}'{% if not loop.last %}, {% endif %}{% endfor %}];
    
    // Add tag function
    function addTag(tagName) {
        const cleanTag = tagName.trim().toLowerCase();
        if (cleanTag && !selectedTags.includes(cleanTag)) {
            selectedTags.push(cleanTag);
            renderSelectedTags();
            updateTagInputs();
        }
    }
    
    // Remove tag function
    function removeTag(tagName) {
        const index = selectedTags.indexOf(tagName);
        if (index > -1) {
            selectedTags.splice(index, 1);
            renderSelectedTags();
            updateTagInputs();
        }
    }
    
    // Render selected tags
    function renderSelectedTags() {
        selectedTagsContainer.innerHTML = '';
        
        if (selectedTags.length === 0) {
            selectedTagsContainer.innerHTML = '<span class="text-sm text-gray-500 italic">No tags selected</span>';
            return;
        }
        
        selectedTags.forEach(tag => {
            const tagElement = document.createElement('span');
            tagElement.className = 'inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800 border border-blue-200';
            tagElement.innerHTML = `
                ${tag}
                <button type="button" class="ml-2 inline-flex items-center justify-center w-4 h-4 rounded-full text-blue-600 hover:bg-blue-200 hover:text-blue-800 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-colors duration-200" onclick="removeTag('${tag}')">
                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            `;
            selectedTagsContainer.appendChild(tagElement);
        });
    }
    
    // Update hidden inputs for form submission
    function updateTagInputs() {
        // Remove existing tag inputs
        const existingInputs = document.querySelectorAll('input[name="tags[]"]');
        existingInputs.forEach(input => input.remove());
        
        // Add new tag inputs
        selectedTags.forEach(tag => {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'tags[]';
            input.value = tag;
            document.getElementById('eventEditForm').appendChild(input);
        });
    }
    
    // Handle tag input
    tagInput.addEventListener('keydown', function(e) {
        if (e.key === 'Enter' || e.key === ',') {
            e.preventDefault();
            const tagName = this.value.trim();
            if (tagName) {
                addTag(tagName);
                this.value = '';
            }
        }
    });
    
    // Handle tag input blur
    tagInput.addEventListener('blur', function() {
        const tagName = this.value.trim();
        if (tagName) {
            addTag(tagName);
            this.value = '';
        }
    });
    
    // Handle popular tag clicks
    popularTagButtons.forEach(button => {
        button.addEventListener('click', function() {
            const tagName = this.getAttribute('data-tag');
            addTag(tagName);
        });
    });
    
    // Make removeTag function global
    window.removeTag = removeTag;
    
    // Initialize tags display
    renderSelectedTags();
    updateTagInputs();
});

