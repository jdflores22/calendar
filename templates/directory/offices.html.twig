{% extends 'base.html.twig' %}

{% block title %}Office Management{% endblock %}

{% block body %}
<div class="space-y-6">
    <!-- Header -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-bold text-slate-900">Office Management</h1>
            <p class="mt-1 text-sm text-slate-600">Manage organizational offices grouped by clusters</p>
        </div>
        <a href="{{ path('directory_office_new') }}" class="inline-flex items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700 transition-colors duration-200">
            <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
            Add Office
        </a>
    </div>

    <!-- Flash Messages -->
    {% for message in app.flashes('success') %}
        <div class="bg-green-50 border-l-4 border-green-500 p-4 rounded">
            <div class="flex">
                <svg class="h-5 w-5 text-green-500" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                </svg>
                <p class="ml-3 text-sm text-green-700">{{ message }}</p>
            </div>
        </div>
    {% endfor %}

    {% for message in app.flashes('error') %}
        <div class="bg-red-50 border-l-4 border-red-500 p-4 rounded">
            <div class="flex">
                <svg class="h-5 w-5 text-red-500" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
                </svg>
                <p class="ml-3 text-sm text-red-700">{{ message }}</p>
            </div>
        </div>
    {% endfor %}

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-4">
            <div class="flex items-center">
                <div class="w-12 h-12 bg-indigo-100 rounded-lg flex items-center justify-center">
                    <svg class="h-6 w-6 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-4m-5 0H9m0 0H5m0 0h2M7 7h10M7 11h10M7 15h10"></path>
                    </svg>
                </div>
                <div class="ml-4">
                    <p class="text-sm font-medium text-slate-500">Total Offices</p>
                    <p class="text-2xl font-semibold text-slate-900">{{ offices|length }}</p>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-4">
            <div class="flex items-center">
                <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center">
                    <svg class="h-6 w-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-4m-5 0H9m0 0H5m0 0h2M7 7h10M7 11h10M7 15h10"></path>
                    </svg>
                </div>
                <div class="ml-4">
                    <p class="text-sm font-medium text-slate-500">With Divisions</p>
                    <p class="text-2xl font-semibold text-slate-900">{{ offices|filter(o => o.divisions|length > 0)|length }}</p>
                </div>
            </div>
        </div>
        <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-4">
            <div class="flex items-center">
                <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center">
                    <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                    </svg>
                </div>
                <div class="ml-4">
                    <p class="text-sm font-medium text-slate-500">Total Staff</p>
                    <p class="text-2xl font-semibold text-slate-900">{{ officeStats|reduce((carry, count) => carry + count, 0) }}</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Search and Filter -->
    <div class="bg-white rounded-lg shadow-sm border border-slate-200 p-4">
        <div class="flex flex-col md:flex-row gap-4">
            <div class="flex-1">
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <svg class="h-5 w-5 text-slate-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                        </svg>
                    </div>
                    <input type="text" id="officeSearch" 
                           class="block w-full pl-10 pr-3 py-2 border border-slate-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500"
                           placeholder="Search by office name or code...">
                </div>
            </div>
            <button onclick="clearOfficeFilters()" 
                    class="px-4 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 font-medium rounded-lg transition-colors duration-200">
                Clear
            </button>
        </div>
    </div>

    <!-- Offices Grouped by Cluster -->
    {% if offices is empty %}
        <div class="bg-white rounded-lg shadow-sm border border-slate-200">
            <div class="text-center py-12">
                <svg class="mx-auto h-12 w-12 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-4m-5 0H9m0 0H5m0 0h2M7 7h10M7 11h10M7 15h10"></path>
                </svg>
                <h3 class="mt-2 text-sm font-medium text-slate-900">No offices</h3>
                <p class="mt-1 text-sm text-slate-500">Get started by creating a new office.</p>
                <div class="mt-6">
                    <a href="{{ path('directory_office_new') }}" class="inline-flex items-center px-4 py-2 bg-indigo-600 text-white text-sm font-medium rounded-lg hover:bg-indigo-700">
                        <svg class="w-5 h-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                        </svg>
                        Create Office
                    </a>
                </div>
            </div>
        </div>
    {% else %}
        {# Get all unique clusters #}
        {% set clusters = [] %}
        {% set clusterIds = [] %}
        {% for office in offices %}
            {% if office.cluster and office.cluster.id not in clusterIds %}
                {% set clusters = clusters|merge([office.cluster]) %}
                {% set clusterIds = clusterIds|merge([office.cluster.id]) %}
            {% endif %}
        {% endfor %}

        {# Sort clusters by display order #}
        {% set sortedClusters = clusters|sort((a, b) => a.displayOrder <=> b.displayOrder) %}

        {# Display each cluster with its offices #}
        {% for cluster in sortedClusters %}
            {% set clusterOffices = offices|filter(o => o.cluster and o.cluster.id == cluster.id) %}
            {% if clusterOffices|length > 0 %}
            <div class="bg-white rounded-lg shadow-sm border border-slate-200 overflow-hidden cluster-section">
                <!-- Cluster Header -->
                <div class="px-6 py-4 border-b border-slate-200" style="background: linear-gradient(to right, {{ cluster.color }}10, {{ cluster.color }}05);">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center">
                            <div class="w-10 h-10 rounded-lg flex items-center justify-center mr-3" style="background-color: {{ cluster.color }};">
                                <span class="text-sm font-bold text-white">{{ cluster.code|slice(0, 2)|upper }}</span>
                            </div>
                            <div>
                                <h3 class="text-lg font-semibold text-slate-900">{{ cluster.name }}</h3>
                                <p class="text-sm text-slate-600">{{ clusterOffices|length }} office{{ clusterOffices|length != 1 ? 's' : '' }}</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Offices Table -->
                <table class="min-w-full divide-y divide-slate-200">
                    <thead class="bg-slate-50">
                        <tr>
                            <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Office</th>
                            <th class="px-3 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Code</th>
                            <th class="px-3 py-3 text-center text-xs font-medium text-slate-500 uppercase tracking-wider">Staff</th>
                            <th class="px-3 py-3 text-center text-xs font-medium text-slate-500 uppercase tracking-wider">Divisions</th>
                            <th class="px-4 py-3 text-right text-xs font-medium text-slate-500 uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-slate-200">
                        {% for office in clusterOffices %}
                        <tr class="hover:bg-slate-50 transition-colors duration-150 office-row" data-office-name="{{ office.name|lower }}" data-office-code="{{ office.code|lower }}">
                            <td class="px-4 py-4">
                                <div class="flex items-center">
                                    <div class="flex-shrink-0 h-10 w-10 rounded-lg flex items-center justify-center" style="background-color: {{ office.effectiveColor }};">
                                        <span class="text-sm font-semibold text-white">
                                            {{ office.code|slice(0, 2)|upper }}
                                        </span>
                                    </div>
                                    <div class="ml-4">
                                        <div class="text-sm font-medium text-slate-900">{{ office.name }}</div>
                                        {% if office.description %}
                                        <div class="text-xs text-slate-500 mt-1">{{ office.description|slice(0, 50) }}{% if office.description|length > 50 %}...{% endif %}</div>
                                        {% endif %}
                                    </div>
                                </div>
                            </td>
                            <td class="px-3 py-4 whitespace-nowrap">
                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-slate-100 text-slate-800">
                                    {{ office.code }}
                                </span>
                            </td>
                            <td class="px-3 py-4 whitespace-nowrap text-center">
                                <span class="inline-flex items-center justify-center w-8 h-8 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                                    {{ officeStats[office.id] ?? 0 }}
                                </span>
                            </td>
                            <td class="px-3 py-4 whitespace-nowrap text-center">
                                <span class="inline-flex items-center justify-center w-8 h-8 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
                                    {{ office.divisions|length }}
                                </span>
                            </td>
                            <td class="px-4 py-4 whitespace-nowrap text-right text-sm font-medium">
                                <div class="flex items-center justify-end space-x-2">
                                    <a href="{{ path('directory_office_edit', {id: office.id}) }}" 
                                       class="inline-flex items-center px-2.5 py-1.5 bg-blue-50 text-blue-700 hover:bg-blue-100 rounded-lg transition-colors duration-200">
                                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                        </svg>
                                        <span class="ml-1">Edit</span>
                                    </a>
                                    <button onclick="deleteOffice({{ office.id }}, '{{ office.name|e('js') }}', '{{ csrf_token('delete' ~ office.id) }}')" 
                                            class="inline-flex items-center px-2.5 py-1.5 bg-red-50 text-red-700 hover:bg-red-100 rounded-lg transition-colors duration-200">
                                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                        </svg>
                                        <span class="ml-1">Delete</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% endif %}
        {% endfor %}

        {# Display offices without cluster #}
        {% set unassignedOffices = offices|filter(o => o.cluster is null) %}
        {% if unassignedOffices|length > 0 %}
            <div class="bg-white rounded-lg shadow-sm border border-slate-200 overflow-hidden cluster-section">
                <!-- Unassigned Header -->
                <div class="px-6 py-4 border-b border-slate-200" style="background: linear-gradient(to right, #f1f5f9, #f8fafc);">
                    <div class="flex items-center justify-between">
                        <div class="flex items-center">
                            <div class="w-10 h-10 rounded-lg flex items-center justify-center mr-3 bg-slate-200">
                                <svg class="w-6 h-6 text-slate-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-4m-5 0H9m0 0H5m0 0h2M7 7h10M7 11h10M7 15h10"></path>
                                </svg>
                            </div>
                            <div>
                                <h3 class="text-lg font-semibold text-slate-900">Unassigned Offices</h3>
                                <p class="text-sm text-slate-600">{{ unassignedOffices|length }} office{{ unassignedOffices|length != 1 ? 's' : '' }} without cluster</p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Offices Table -->
                <table class="min-w-full divide-y divide-slate-200">
                    <thead class="bg-slate-50">
                        <tr>
                            <th class="px-4 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Office</th>
                            <th class="px-3 py-3 text-left text-xs font-medium text-slate-500 uppercase tracking-wider">Code</th>
                            <th class="px-3 py-3 text-center text-xs font-medium text-slate-500 uppercase tracking-wider">Staff</th>
                            <th class="px-3 py-3 text-center text-xs font-medium text-slate-500 uppercase tracking-wider">Divisions</th>
                            <th class="px-4 py-3 text-right text-xs font-medium text-slate-500 uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-slate-200">
                        {% for office in unassignedOffices %}
                        <tr class="hover:bg-slate-50 transition-colors duration-150 office-row" data-office-name="{{ office.name|lower }}" data-office-code="{{ office.code|lower }}">
                            <td class="px-4 py-4">
                                <div class="flex items-center">
                                    <div class="flex-shrink-0 h-10 w-10 rounded-lg flex items-center justify-center" style="background-color: {{ office.effectiveColor }};">
                                        <span class="text-sm font-semibold text-white">
                                            {{ office.code|slice(0, 2)|upper }}
                                        </span>
                                    </div>
                                    <div class="ml-4">
                                        <div class="text-sm font-medium text-slate-900">{{ office.name }}</div>
                                        {% if office.description %}
                                        <div class="text-xs text-slate-500 mt-1">{{ office.description|slice(0, 50) }}{% if office.description|length > 50 %}...{% endif %}</div>
                                        {% endif %}
                                    </div>
                                </div>
                            </td>
                            <td class="px-3 py-4 whitespace-nowrap">
                                <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-slate-100 text-slate-800">
                                    {{ office.code }}
                                </span>
                            </td>
                            <td class="px-3 py-4 whitespace-nowrap text-center">
                                <span class="inline-flex items-center justify-center w-8 h-8 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
                                    {{ officeStats[office.id] ?? 0 }}
                                </span>
                            </td>
                            <td class="px-3 py-4 whitespace-nowrap text-center">
                                <span class="inline-flex items-center justify-center w-8 h-8 rounded-full text-xs font-medium bg-purple-100 text-purple-800">
                                    {{ office.divisions|length }}
                                </span>
                            </td>
                            <td class="px-4 py-4 whitespace-nowrap text-right text-sm font-medium">
                                <div class="flex items-center justify-end space-x-2">
                                    <a href="{{ path('directory_office_edit', {id: office.id}) }}" 
                                       class="inline-flex items-center px-2.5 py-1.5 bg-blue-50 text-blue-700 hover:bg-blue-100 rounded-lg transition-colors duration-200">
                                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                        </svg>
                                        <span class="ml-1">Edit</span>
                                    </a>
                                    <button onclick="deleteOffice({{ office.id }}, '{{ office.name|e('js') }}', '{{ csrf_token('delete' ~ office.id) }}')" 
                                            class="inline-flex items-center px-2.5 py-1.5 bg-red-50 text-red-700 hover:bg-red-100 rounded-lg transition-colors duration-200">
                                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                        </svg>
                                        <span class="ml-1">Delete</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    {% endif %}
</div>

<!-- Delete Confirmation Modal -->
<div id="deleteModal" class="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 hidden">
    <div class="bg-white rounded-xl shadow-2xl p-6 max-w-md w-full mx-4">
        <h3 class="text-lg font-semibold text-slate-900 mb-2">Confirm Delete</h3>
        <p class="text-sm text-slate-600 mb-6">Are you sure you want to delete office "<span id="officeName" class="font-medium"></span>"? This action cannot be undone.</p>
        <div class="flex justify-end space-x-3">
            <button onclick="closeDeleteModal()" class="px-4 py-2 text-sm font-medium text-slate-700 bg-slate-100 rounded-lg hover:bg-slate-200 transition-colors duration-200">
                Cancel
            </button>
            <form id="deleteForm" method="POST" class="inline">
                <input type="hidden" name="_token" id="deleteToken">
                <button type="submit" class="px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-lg hover:bg-red-700 transition-colors duration-200">
                    Delete
                </button>
            </form>
        </div>
    </div>
</div>

<script>
function deleteOffice(officeId, officeName, csrfToken) {
    document.getElementById('officeName').textContent = officeName;
    document.getElementById('deleteForm').action = '{{ path('directory_office_delete', {id: '__ID__'}) }}'.replace('__ID__', officeId);
    document.getElementById('deleteToken').value = csrfToken;
    document.getElementById('deleteModal').classList.remove('hidden');
}

function closeDeleteModal() {
    document.getElementById('deleteModal').classList.add('hidden');
}

function clearOfficeFilters() {
    document.getElementById('officeSearch').value = '';
    filterOffices();
}

function filterOffices() {
    const searchTerm = document.getElementById('officeSearch').value.toLowerCase();
    const rows = document.querySelectorAll('.office-row');
    const sections = document.querySelectorAll('.cluster-section');
    
    rows.forEach(row => {
        const name = row.getAttribute('data-office-name');
        const code = row.getAttribute('data-office-code');
        
        if (name.includes(searchTerm) || code.includes(searchTerm)) {
            row.style.display = '';
        } else {
            row.style.display = 'none';
        }
    });
    
    // Hide empty cluster sections
    sections.forEach(section => {
        const visibleRows = section.querySelectorAll('.office-row:not([style*="display: none"])');
        if (visibleRows.length === 0 && searchTerm !== '') {
            section.style.display = 'none';
        } else {
            section.style.display = '';
        }
    });
}

document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('officeSearch');
    if (searchInput) {
        searchInput.addEventListener('input', filterOffices);
    }
    
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            closeDeleteModal();
        }
    });
});
</script>
{% endblock %}
