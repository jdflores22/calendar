{% extends 'base.html.twig' %}

{% block title %}{{ action }} Office{% endblock %}

{% block body %}
<div class="min-h-screen bg-gradient-to-br from-slate-50 to-blue-50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <!-- Enhanced Header -->
        <div class="mb-8">
            <div class="flex flex-col lg:flex-row lg:justify-between lg:items-start gap-6">
                <div class="flex-1">
                    <div class="flex items-center space-x-4">
                        <a href="{{ path('directory_offices') }}" 
                           class="p-2 text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition-all duration-200">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                            </svg>
                        </a>
                        <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center">
                            <svg class="h-6 w-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-4m-5 0H9m0 0H5m0 0h2M7 7h10M7 11h10M7 15h10"></path>
                            </svg>
                        </div>
                        <div>
                            <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 leading-tight">{{ action }} Office</h1>
                            <p class="mt-2 text-base text-gray-600 leading-relaxed">
                                {{ action == 'Create' ? 'Add a new office to the organizational structure' : 'Update office information and settings' }}
                            </p>
                        </div>
                    </div>
                </div>
                
                <!-- Progress Indicator for Create -->
                {% if action == 'Create' %}
                <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-4">
                    <div class="flex items-center space-x-3">
                        <div class="flex-shrink-0">
                            <div class="w-8 h-8 bg-blue-100 rounded-full flex items-center justify-center">
                                <svg class="w-4 h-4 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                                </svg>
                            </div>
                        </div>
                        <div>
                            <p class="text-sm font-medium text-gray-900">Creating New Office</p>
                            <p class="text-xs text-gray-500">Step 1 of 1</p>
                        </div>
                    </div>
                </div>
                {% endif %}
            </div>
        </div>

        <!-- Form Container -->
        <div class="bg-white shadow-xl rounded-xl border border-gray-200 overflow-hidden">
            <!-- Form Header -->
            <div class="px-6 py-4 border-b border-gray-200 bg-gradient-to-r from-gray-50 to-white">
                <div class="flex items-center space-x-3">
                    <div class="w-8 h-8 bg-green-100 rounded-lg flex items-center justify-center">
                        <svg class="w-5 h-5 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                        </svg>
                    </div>
                    <div>
                        <h3 class="text-lg font-semibold text-gray-900">Office Information</h3>
                        <p class="text-sm text-gray-600">Fill in the details below to {{ action|lower }} the office</p>
                    </div>
                </div>
            </div>

            <!-- Form -->
            <form method="POST" id="officeForm" class="p-6 space-y-8">
                <!-- Basic Information Section -->
                <div class="space-y-6">
                    <div class="flex items-center space-x-3 mb-4">
                        <div class="w-6 h-6 bg-blue-100 rounded-full flex items-center justify-center">
                            <span class="text-xs font-semibold text-blue-600">1</span>
                        </div>
                        <h4 class="text-lg font-medium text-gray-900">Basic Information</h4>
                    </div>

                    <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
                        <!-- Office Name -->
                        <div class="lg:col-span-2">
                            <label for="name" class="block text-sm font-medium text-gray-700 mb-2">
                                Office Name <span class="text-red-500">*</span>
                            </label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                    <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-4m-5 0H9m0 0H5m0 0h2M7 7h10M7 11h10M7 15h10"></path>
                                    </svg>
                                </div>
                                <input type="text" name="name" id="name" required
                                       value="{{ office.name ?? '' }}"
                                       placeholder="e.g., Information Technology Department"
                                       class="pl-10 block w-full border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-all duration-200 sm:text-sm">
                            </div>
                            <p class="mt-2 text-sm text-gray-500">Enter the full name of the office or department</p>
                        </div>

                        <!-- Office Code -->
                        <div>
                            <label for="code" class="block text-sm font-medium text-gray-700 mb-2">
                                Office Code <span class="text-red-500">*</span>
                            </label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                    <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 20l4-16m2 16l4-16M6 9h14M4 15h14"></path>
                                    </svg>
                                </div>
                                <input type="text" name="code" id="code" required
                                       value="{{ office.code ?? '' }}"
                                       placeholder="e.g., IT, HR, FIN"
                                       maxlength="10"
                                       class="pl-10 block w-full border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-all duration-200 sm:text-sm uppercase">
                            </div>
                            <p class="mt-2 text-sm text-gray-500">Short abbreviation (2-10 characters)</p>
                        </div>

                        <!-- Cluster -->
                        <div>
                            <label for="cluster_id" class="block text-sm font-medium text-gray-700 mb-2">
                                Cluster
                            </label>
                            <div class="relative">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none z-10">
                                    <svg class="h-5 w-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                                    </svg>
                                </div>
                                <select name="cluster_id" id="cluster_id"
                                        class="pl-10 pr-12 block w-full border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-all duration-200 sm:text-sm appearance-none"
                                        style="background-image: url('data:image/svg+xml;charset=UTF-8,%3csvg xmlns=%27http://www.w3.org/2000/svg%27 viewBox=%270 0 20 20%27 fill=%27none%27%3e%3cpath d=%27M7 7l3 3 3-3%27 stroke=%27%239CA3AF%27 stroke-width=%271.5%27 stroke-linecap=%27round%27 stroke-linejoin=%27round%27/%3e%3c/svg%3e'); background-position: right 0.5rem center; background-repeat: no-repeat; background-size: 1.5em 1.5em;">
                                    <option value="" data-color="">No cluster</option>
                                    {% for cluster in clusters %}
                                        <option value="{{ cluster.id }}" 
                                                data-color="{{ cluster.color|default('') }}"
                                                {% if office.cluster and office.cluster.id == cluster.id %}selected{% endif %}>
                                            {{ cluster.name }} ({{ cluster.code }})
                                        </option>
                                    {% endfor %}
                                </select>
                                <div id="clusterColorIndicator" class="absolute inset-y-0 right-10 flex items-center pr-1 pointer-events-none z-10">
                                    {% if office.cluster and office.cluster.color %}
                                    <div class="w-5 h-5 rounded-full border-2 border-white shadow-sm" style="background-color: {{ office.cluster.color }}"></div>
                                    {% endif %}
                                </div>
                    </div>
                </div>

                <!-- Visual Identity Section -->
                <div class="space-y-6 pt-6 border-t border-gray-200">
                    <div class="flex items-center space-x-3 mb-4">
                        <div class="w-6 h-6 bg-purple-100 rounded-full flex items-center justify-center">
                            <span class="text-xs font-semibold text-purple-600">2</span>
                        </div>
                        <h4 class="text-lg font-medium text-gray-900">Visual Identity</h4>
                    </div>

                    <!-- Cluster Color Display (Read-only) -->
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">
                            Office Color
                        </label>
                        
                        <div class="p-4 bg-gradient-to-r from-blue-50 to-indigo-50 border border-blue-200 rounded-lg">
                            <div class="flex items-center space-x-4">
                                <div class="flex-shrink-0">
                                    <div id="displayColorPreview" class="w-16 h-16 rounded-lg border-2 border-white shadow-md" 
                                         style="background-color: {{ office.cluster ? office.cluster.color : '#3B82F6' }};"></div>
                                </div>
                                <div class="flex-1">
                                    <p class="text-sm font-semibold text-gray-900 mb-1">
                                        <svg class="w-4 h-4 inline mr-1 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                        </svg>
                                        Color inherited from cluster
                                    </p>
                                    <p class="text-xs text-gray-600 leading-relaxed">
                                        This office will use the same color as its cluster. All offices and divisions in the same cluster share the same color for visual consistency across the system.
                                    </p>
                                    {% if clusters|length > 0 %}
                                    <p class="text-xs text-blue-700 mt-2">
                                        💡 To change the color, update the cluster's color in the 
                                        <a href="{{ path('admin_cluster_index') }}" class="underline font-medium hover:text-blue-800">cluster management</a> section.
                                    </p>
                                    {% endif %}
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Additional Information Section -->
                <div class="space-y-6 pt-6 border-t border-gray-200">
                    <div class="flex items-center space-x-3 mb-4">
                        <div class="w-6 h-6 bg-orange-100 rounded-full flex items-center justify-center">
                            <span class="text-xs font-semibold text-orange-600">3</span>
                        </div>
                        <h4 class="text-lg font-medium text-gray-900">Additional Information</h4>
                    </div>

                    <!-- Description -->
                    <div>
                        <label for="description" class="block text-sm font-medium text-gray-700 mb-2">
                            Description
                        </label>
                        <div class="relative">
                            <textarea name="description" id="description" rows="4"
                                      placeholder="Describe the office's role, responsibilities, and purpose..."
                                      class="block w-full border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-all duration-200 sm:text-sm resize-none">{{ office.description ?? '' }}</textarea>
                            <div class="absolute bottom-3 right-3 text-xs text-gray-400">
                                <span id="charCount">0</span>/500
                            </div>
                        </div>
                        <p class="mt-2 text-sm text-gray-500">Optional description of the office's role and responsibilities</p>
                    </div>
                </div>

                <!-- Form Actions -->
                <div class="pt-6 border-t border-gray-200 space-y-4">
                    <div class="flex items-center justify-center sm:justify-start space-x-2 text-sm text-gray-500">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                        <span>Fields marked with <span class="text-red-500">*</span> are required</span>
                    </div>
                    
                    <div class="flex flex-col sm:flex-row gap-3 justify-end">
                        <a href="{{ path('directory_offices') }}" 
                           class="w-full sm:w-auto inline-flex items-center justify-center px-6 py-3 border-2 border-gray-300 rounded-lg text-sm font-semibold text-gray-700 bg-white hover:bg-gray-50 hover:border-gray-400 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-500 transition-all duration-200 shadow-sm">
                            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                            </svg>
                            Cancel
                        </a>
                        <button type="submit" id="submitBtn"
                                class="w-full sm:w-auto inline-flex items-center justify-center px-6 py-3 border-2 border-transparent rounded-lg text-sm font-semibold text-white bg-gradient-to-r from-green-600 to-green-700 hover:from-green-700 hover:to-green-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-green-500 transition-all duration-200 shadow-md hover:shadow-lg">
                            <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                            </svg>
                            <span id="submitText">{{ action }} Office</span>
                        </button>
                    </div>
                </div>
            </form>
        </div>

        <!-- Help Section -->
        <div class="mt-8 bg-blue-50 border border-blue-200 rounded-lg p-6">
            <div class="flex">
                <div class="flex-shrink-0">
                    <svg class="h-5 w-5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                </div>
                <div class="ml-3">
                    <h3 class="text-sm font-medium text-blue-800">Tips for Creating Offices</h3>
                    <div class="mt-2 text-sm text-blue-700">
                        <ul class="list-disc list-inside space-y-1">
                            <li><strong>Office Name:</strong> Use the full, official name of the department or office</li>
                            <li><strong>Office Code:</strong> Keep it short and memorable (2-10 characters)</li>
                            <li><strong>Parent Office:</strong> Create departments first, then add sub-offices under them</li>
                            <li><strong>Color:</strong> Choose distinct colors to help differentiate offices in calendars and reports</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const description = document.getElementById('description');
    const charCount = document.getElementById('charCount');
    const form = document.getElementById('officeForm');
    const submitBtn = document.getElementById('submitBtn');
    const submitText = document.getElementById('submitText');
    const codeInput = document.getElementById('code');
    const clusterSelect = document.getElementById('cluster_id');
    const colorPreview = document.getElementById('displayColorPreview');

    // Update color preview when cluster changes
    function updateClusterColor() {
        const selectedOption = clusterSelect.options[clusterSelect.selectedIndex];
        const color = selectedOption.getAttribute('data-color') || '#3B82F6';
        
        if (colorPreview) {
            colorPreview.style.backgroundColor = color;
        }
    }

    if (clusterSelect) {
        clusterSelect.addEventListener('change', updateClusterColor);
        updateClusterColor(); // Initialize on load
    }

    // Character count for description
    function updateCharCount() {
        const count = description.value.length;
        charCount.textContent = count;
        
        if (count > 500) {
            charCount.classList.add('text-red-500');
            description.value = description.value.substring(0, 500);
            charCount.textContent = '500';
        } else {
            charCount.classList.remove('text-red-500');
        }
    }

    description.addEventListener('input', updateCharCount);
    updateCharCount(); // Initial count

    // Auto-uppercase office code
    codeInput.addEventListener('input', function() {
        this.value = this.value.toUpperCase();
    });

    // Form submission with loading state
    form.addEventListener('submit', function(e) {
        submitBtn.disabled = true;
        submitBtn.classList.add('opacity-75', 'cursor-not-allowed');
        submitText.innerHTML = `
            <svg class="animate-spin w-4 h-4 mr-2 inline" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
            </svg>
            {{ action == 'Create' ? 'Creating...' : 'Updating...' }}
        `;
    });

    // Form validation
    const requiredFields = form.querySelectorAll('[required]');
    
    function validateForm() {
        let isValid = true;
        
        requiredFields.forEach(field => {
            if (!field.value.trim()) {
                isValid = false;
                field.classList.add('border-red-300', 'focus:border-red-500', 'focus:ring-red-500');
            } else {
                field.classList.remove('border-red-300', 'focus:border-red-500', 'focus:ring-red-500');
            }
        });
        
        return isValid;
    }

    // Real-time validation
    requiredFields.forEach(field => {
        field.addEventListener('blur', validateForm);
        field.addEventListener('input', function() {
            if (this.value.trim()) {
                this.classList.remove('border-red-300', 'focus:border-red-500', 'focus:ring-red-500');
            }
        });
    });
});
</script>
{% endblock %}